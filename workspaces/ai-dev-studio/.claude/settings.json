{
  "mcpServers": {
    "ads-workspace": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "D:\\Code\\ai-dev-net\\ai-dev.mcp",
        "--",
        "D:\\Code\\ai-dev-net\\workspaces"
      ]
    }
  },
  "permissions": {
    "allow": [
      "mcp__ads-workspace__*"
    ],
    "deny": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Glob",
      "Grep",
      "NotebookRead",
      "NotebookEdit"
    ]
  },
  "defaultMode": "dontAsk"
}