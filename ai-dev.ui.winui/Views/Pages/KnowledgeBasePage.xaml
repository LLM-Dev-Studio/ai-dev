<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.KnowledgeBasePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: articles list -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Knowledge Base"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,12" />

            <!-- New article form -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         PlaceholderText="article-slug"
                         Text="{Binding NewArticleSlug, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Content="+"
                        Command="{Binding CreateArticleCommand}" />
            </Grid>

            <ListView Grid.Row="2"
                      ItemsSource="{Binding Articles}"
                      SelectedItem="{Binding SelectedArticle, Mode=TwoWay}"
                      SelectionChanged="Article_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <TextBlock Text="{Binding Slug}"
                                       Padding="4"
                                       VerticalAlignment="Center" />
                            <Button Content="✕"
                                    HorizontalAlignment="Right"
                                    Tag="{Binding}"
                                    Click="DeleteArticle_Click"
                                    Padding="6,2" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right: article editor -->
        <Grid Grid.Column="1"
              Visibility="{Binding SelectedArticle, Converter={StaticResource NullToVisible}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="{Binding SelectedArticle.Slug}"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <TextBlock Text="Unsaved changes"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisible}}" />
                    <Button Content="Save"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding SaveArticleCommand}"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolToVisible}}" />
                </StackPanel>
            </Grid>

            <Pivot Grid.Row="1">
                <PivotItem Header="Editor">
                    <TextBox Text="{Binding ArticleContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="13"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </PivotItem>
                <PivotItem Header="Preview">
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <WebView2 x:Name="PreviewWebView"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" />
                    </Border>
                </PivotItem>
            </Pivot>

            <TextBlock Grid.Row="2"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"
                       Text="Markdown editor" />
        </Grid>
    </Grid>
</Page>
