<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.AgentDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:AgentStatusColorConverter x:Key="StatusColor" />
        <conv:AgentStatusTextConverter x:Key="StatusText" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Agents" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Manage and run agents for this project"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Content="Add Agent"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="AddAgent_Click" />
        </Grid>

        <!-- Failover alert bar -->
        <InfoBar Grid.Row="1"
                 IsOpen="{Binding HasFailoverAlerts}"
                 Severity="Warning"
                 Title="Executor Failover Detected"
                 Margin="0,0,0,12"
                 IsClosable="False">
            <InfoBar.Content>
                <ItemsControl ItemsSource="{Binding FailoverAlerts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Margin="0,2,0,0" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </InfoBar.Content>
        </InfoBar>

        <!-- Loading -->
        <ProgressRing Grid.Row="2"
                      IsActive="{Binding IsLoading}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Agent cards -->
        <GridView Grid.Row="2"
                  ItemsSource="{Binding Agents}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0,0,16,16" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Border Width="300" Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Name + status -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10"
                                             Fill="{Binding Agent.Status, Converter={StaticResource StatusColor}}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Agent.Name}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </StackPanel>
                                <TextBlock Text="{Binding Agent.Status, Converter={StaticResource StatusText}}"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>

                            <!-- Role + model -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="{Binding Agent.Role}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <TextBlock Text="{Binding Agent.Model}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}">
                                        <TextBlock Text="{Binding Agent.Executor.Value}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Description -->
                            <TextBlock Grid.Row="2"
                                       Margin="0,4,0,0"
                                       Text="{Binding Agent.Description}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis"
                                       IsTabStop="True"
                                       ToolTipService.ToolTip="{Binding Agent.Description}"
                                       AutomationProperties.HelpText="{Binding Agent.Description}"
                                       Visibility="{Binding Agent.Description, Converter={StaticResource NullToVisible}}" />

                            <!-- Inbox count + last run -->
                            <Grid Grid.Row="3" Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                    <Run Text="{Binding Agent.InboxCount, Mode=OneWay}" /><Run Text=" inbox" />
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Right"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                    <Run Text="Last run: " /><Run Text="{Binding Agent.LastRunAt}" />
                                </TextBlock>
                            </Grid>

                            <!-- Action buttons: single Run/Stop toggle + Details -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                                <!-- Run: shown when not running -->
                                <Button Content="Run"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Tag="{Binding}"
                                        Click="RunAgent_Click"
                                        Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisible}}" />
                                <!-- Stop: shown when running -->
                                <Button Content="Stop"
                                        Tag="{Binding}"
                                        Click="StopAgent_Click"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisible}}" />
                                <Button Content="Details"
                                        Tag="{Binding}"
                                        Click="SelectAgent_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
