<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.SecretsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Secrets" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Encrypted at rest. Values are never displayed after saving."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Add secret form -->
        <Border Grid.Row="1" Margin="0,0,0,16" Padding="16" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock Text="Add secret" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             PlaceholderText="KEY_NAME"
                             FontFamily="Consolas"
                             Text="{Binding NewKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <PasswordBox Grid.Column="1"
                                 PlaceholderText="value"
                                 Password="{Binding NewValue, Mode=TwoWay}" />
                    <Button Grid.Column="2"
                            Content="Add"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding AddSecretCommand}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Loading -->
        <ProgressRing Grid.Row="2"
                      IsActive="{Binding IsLoading}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Secrets list — names only, no values ever shown -->
        <ListView Grid.Row="2"
                  x:Name="SecretsList"
                  ItemsSource="{Binding SecretNames}"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4" MinHeight="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding}"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="••••••••"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button Grid.Column="2"
                                Content="Delete"
                                Tag="{Binding}"
                                Click="DeleteSecret_Click" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Delete confirmation bar -->
        <Border Grid.Row="3"
                Visibility="{Binding PendingDeleteKey, Converter={StaticResource NullToVisible}}"
                Margin="0,8,0,0" Padding="12,10" CornerRadius="8"
                Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                    <Run Text="Delete secret " />
                    <Run Text="{Binding PendingDeleteKey}" FontFamily="Consolas" FontWeight="SemiBold" />
                    <Run Text="? This cannot be undone." />
                </TextBlock>
                <Button Grid.Column="1"
                        Content="Delete"
                        Margin="0,0,8,0"
                        Command="{Binding ConfirmDeleteCommand}" />
                <Button Grid.Column="2"
                        Content="Cancel"
                        Command="{Binding CancelDeleteCommand}" />
            </Grid>
        </Border>
    </Grid>
</Page>
