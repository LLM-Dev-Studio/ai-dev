<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.TemplatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Agent Templates" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Global starting points for new agents"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Content="New template"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding NewTemplateCommand}" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <ProgressRing IsActive="{Binding IsLoading}"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />

                <ListView ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="4" Spacing="2">
                                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontFamily="Consolas">
                                    <Run Text="{Binding Slug}" /><Run Text=" · " /><Run Text="{Binding Model}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Border Grid.Column="1"
                    Padding="16"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Template editor" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <Grid Grid.Row="1" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Name" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Slug" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox Text="{Binding EditSlug, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsNewTemplate}"
                                         FontFamily="Consolas" />
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                                <TextBlock Text="Role" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox Text="{Binding EditRole, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                                <TextBlock Text="Executor" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox ItemsSource="{Binding AvailableExecutors}"
                                          SelectedItem="{Binding EditExecutor, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
                                <TextBlock Text="Model" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox ItemsSource="{Binding AvailableModels}"
                                          SelectedItem="{Binding EditModel, Mode=TwoWay}"
                                          IsEditable="True"
                                          PlaceholderText="Model id" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="2" Spacing="4">
                                <TextBlock Text="Description" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox Text="{Binding EditDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Pivot Grid.Row="1">
                            <PivotItem Header="Editor">
                                <Grid RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="Instructions editor (CLAUDE.md)"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBox Grid.Row="1"
                                             Text="{Binding EditContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas"
                                             VerticalAlignment="Stretch"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </Grid>
                            </PivotItem>
                            <PivotItem Header="Preview">
                                <Grid RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="Formatted markdown preview"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Border Grid.Row="1"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <WebView2 x:Name="PreviewWebView"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                                    </Border>
                                </Grid>
                            </PivotItem>
                        </Pivot>
                    </Grid>

                    <StackPanel Grid.Row="2" Spacing="8">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisible}}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <TextBlock Text="Saved"
                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding Saved, Converter={StaticResource BoolToVisible}}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                            <Button Content="Delete" Command="{Binding DeleteTemplateCommand}" />
                            <Button Content="Save"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Command="{Binding SaveTemplateCommand}"
                                    IsEnabled="{Binding IsDirty}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
