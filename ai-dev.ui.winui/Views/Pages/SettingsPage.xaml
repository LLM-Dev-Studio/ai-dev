<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
    </Page.Resources>

    <ScrollViewer Margin="24">
        <StackPanel Spacing="20">
            <!-- Header -->
            <Grid>
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="{Binding SaveNote}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <ProgressRing IsActive="{Binding IsLoading}"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                              HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <!-- Two-column card layout -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <!-- Left: AI Providers -->
                <Border Grid.Column="0" Padding="16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="AI Providers" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Anthropic API Key" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <PasswordBox Password="{Binding AnthropicApiKey, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="GitHub Token" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <PasswordBox Password="{Binding GitHubToken, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Ollama Base URL" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{Binding OllamaBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="LM Studio Base URL" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{Binding LmStudioBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Right: Insights -->
                <Border Grid.Column="1" Padding="16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Insights" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Insights Executor" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{Binding InsightsExecutor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Insights Model" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{Binding InsightsModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
