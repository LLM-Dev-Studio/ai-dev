<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.InsightsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <ProgressRing IsActive="{Binding IsLoading}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
            <StackPanel Spacing="16">
                <StackPanel>
                    <TextBlock Text="Insights" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="AI-generated qualitative analysis of completed agent sessions."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <!-- Agent list -->
                    <ListView x:Name="AgentList" Grid.Column="0"
                              ItemsSource="{Binding Agents}"
                              SelectionMode="Single"
                              SelectionChanged="AgentList_SelectionChanged"
                              Margin="0,0,8,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="4,6">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                    <TextBlock Text="{Binding Slug}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               FontFamily="Consolas" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Date list -->
                    <ListView x:Name="DateList" Grid.Column="1"
                              ItemsSource="{Binding Dates}"
                              SelectionMode="Single"
                              SelectionChanged="DateList_SelectionChanged"
                              Margin="0,0,8,0"
                              Visibility="{Binding SelectedAgent, Converter={StaticResource NullToVisible}}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="4,6" Style="{StaticResource CaptionTextBlockStyle}"
                                           Text="{Binding Value}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Insight detail -->
                    <ScrollViewer Grid.Column="2"
                                  Visibility="{Binding SelectedInsight, Converter={StaticResource NullToVisible}}">
                        <StackPanel Spacing="12">
                            <!-- Classification badges + copy -->
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border CornerRadius="12" Padding="8,3"
                                            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}">
                                        <TextBlock x:Name="ClassificationText"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Border>
                                    <Border CornerRadius="12" Padding="8,3"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <TextBlock x:Name="SizeRatingText"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Border>
                                </StackPanel>
                                <Button HorizontalAlignment="Right"
                                        Command="{Binding CopyInsightCommand}"
                                        ToolTipService.ToolTip="Copy insights to clipboard">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                        <TextBlock Text="Copy" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Issues -->
                            <StackPanel x:Name="IssuesPanel" Spacing="8">
                                <TextBlock Text="Issues" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <ItemsControl x:Name="IssuesList" />
                            </StackPanel>

                            <!-- Knowledge gaps -->
                            <StackPanel x:Name="GapsPanel" Spacing="8">
                                <TextBlock Text="Knowledge gaps" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <ItemsControl x:Name="GapsList" />
                            </StackPanel>

                            <!-- Improved prompt -->
                            <StackPanel x:Name="PromptPanel" Spacing="6">
                                <TextBlock Text="Improved prompt suggestion"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="PromptText"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- No insights placeholder -->
                    <TextBlock Grid.Column="2"
                               Text="No insights available for this session."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Top"
                               Visibility="{Binding SelectedDate, Converter={StaticResource NullToVisible}}"
                               x:Name="NoInsightsText" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
