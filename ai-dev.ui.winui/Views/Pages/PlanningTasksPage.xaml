<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.PlanningTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:vm="using:AiDev.WinUI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:InverseBoolConverter         x:Key="InverseBool" />
        <conv:NullToVisibilityConverter    x:Key="NullToVisible" />

        <!-- Message bubble styles -->
        <Style x:Key="UserBubbleStyle" TargetType="Border">
            <Setter Property="Background"   Value="#0078D4" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding"      Value="12,8" />
            <Setter Property="MaxWidth"     Value="480" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin"       Value="80,0,0,0" />
        </Style>

        <Style x:Key="AiBubbleStyle" TargetType="Border">
            <Setter Property="Background"   Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding"      Value="12,8" />
            <Setter Property="MaxWidth"     Value="480" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin"       Value="0,0,80,0" />
            <Setter Property="BorderBrush"  Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Loading indicator -->
            <RowDefinition Height="*" />     <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- Loading overlay -->
        <ProgressBar Grid.Row="0"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}" />

        <!-- Main 2-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />  <!-- Sidebar -->
                <ColumnDefinition Width="*" />    <!-- Main content -->
            </Grid.ColumnDefinitions>

            <!-- ===== SIDEBAR ===== -->
            <Border Grid.Column="0"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollMode="Auto">
                    <StackPanel Margin="12">

                        <!-- Session indicator -->
                        <StackPanel Margin="0,8,0,16"
                                    Visibility="{Binding HasSession, Converter={StaticResource BoolToVisible}}">
                            <TextBlock Text="Session" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding SessionDisplayId}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       FontFamily="Consolas" />
                        </StackPanel>

                        <!-- Phase navigation -->
                        <TextBlock Text="PHASES"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8" />

                        <!-- Phase 1 -->
                        <Border x:Name="Phase1NavItem"
                                Padding="10,8" CornerRadius="6" Margin="0,0,0,4"
                                Background="Transparent"
                                PointerPressed="Phase1Review_Click">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                             x:Name="Phase1Dot" />
                                    <TextBlock x:Name="Phase1Label"
                                               Text="Phase 1 — Business Discovery"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="18,2,0,0">
                                    <TextBlock x:Name="Phase1TurnText"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="(locked)" FontStyle="Italic"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{Binding Phase1Locked, Converter={StaticResource BoolToVisible}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Phase 2 -->
                        <Border x:Name="Phase2NavItem"
                                Padding="10,8" CornerRadius="6" Margin="0,0,0,4"
                                Background="Transparent"
                                PointerPressed="Phase2Review_Click">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                             x:Name="Phase2Dot" />
                                    <TextBlock x:Name="Phase2Label"
                                               Text="Phase 2 — Solution Shaping"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="18,2,0,0">
                                    <TextBlock x:Name="Phase2TurnText"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="(locked)" FontStyle="Italic"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{Binding Phase2Locked, Converter={StaticResource BoolToVisible}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Phase 3 -->
                        <Border Padding="10,8" CornerRadius="6" Margin="0,0,0,16"
                                Background="Transparent">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                             x:Name="Phase3Dot" />
                                    <TextBlock x:Name="Phase3Label"
                                               Text="Phase 3 — Planning &amp; Decomposition"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="Phase3TurnText" Margin="18,2,0,0"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Recent sessions -->
                        <TextBlock Text="RECENT SESSIONS"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,8,0,8" />

                        <ItemsControl ItemsSource="{Binding RecentSessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlanningSessionListItem">
                                    <Button Tag="{Binding SessionId}"
                                            Click="RecentSession_Click"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4,4"
                                            Margin="0,0,0,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayId}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       FontFamily="Consolas" />
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Phase}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding CreatedAt}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- New session button -->
                        <Button Content="+ New Session"
                                Click="NewSession_Click"
                                HorizontalAlignment="Stretch"
                                Margin="0,12,0,0"
                                Style="{StaticResource AccentButtonStyle}" />

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Phase accent + role badge -->
                    <RowDefinition Height="*" />     <!-- Conversation panel -->
                    <RowDefinition Height="Auto" />  <!-- DSL panel (collapsible) -->
                    <RowDefinition Height="Auto" />  <!-- Warning banners -->
                    <RowDefinition Height="Auto" />  <!-- Input area -->
                </Grid.RowDefinitions>

                <!-- No session state -->
                <StackPanel Grid.Row="0" Grid.RowSpan="5"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12"
                            Visibility="{Binding HasSession, Converter={StaticResource InverseBoolToVisible}}">
                    <TextBlock Text="No active planning session"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Start a new session to begin planning your software project."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <Button Content="Start New Session"
                            Click="NewSession_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Phase header (when session active) -->
                <Grid Grid.Row="0"
                      Visibility="{Binding HasSession, Converter={StaticResource BoolToVisible}}"
                      Margin="16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />   <!-- Phase accent line -->
                        <ColumnDefinition Width="*" />   <!-- Phase info -->
                        <ColumnDefinition Width="Auto" /><!-- Actions -->
                    </Grid.ColumnDefinitions>

                    <!-- Phase accent bar -->
                    <Border Grid.Column="0" x:Name="PhaseAccentBar"
                            Width="4" CornerRadius="2" VerticalAlignment="Stretch" />

                    <!-- Phase title + role badge -->
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="2">
                        <TextBlock x:Name="PhaseTitleText"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="PhaseRoleBadge"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontStyle="Italic"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- Phase actions (proceed / generate DSL) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="GenerateDslButton"
                                Content="Generate DSL"
                                Click="GenerateDsl_Click"
                                Visibility="{Binding IsLlmResponding, Converter={StaticResource InverseBoolToVisible}}" />
                        <Button x:Name="ProceedButton"
                                Content="Proceed to Next Phase"
                                Click="ProceedPhase_Click"
                                Visibility="{Binding HasDraftDsl, Converter={StaticResource BoolToVisible}}" />
                    </StackPanel>
                </Grid>

                <!-- Error banner -->
                <Border Grid.Row="1" VerticalAlignment="Top"
                        Background="#FFF4CE" Padding="12,8" CornerRadius="4" Margin="16,4"
                        BorderBrush="#F7A800" BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisible}}"
                        Canvas.ZIndex="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="!" FontWeight="Bold" Foreground="#7D5A00" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   TextWrapping="Wrap" Foreground="#7D5A00"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button Content="Dismiss" Click="DismissError_Click"
                                Padding="6,2" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Conversation panel -->
                <ScrollViewer Grid.Row="1"
                              x:Name="ConversationScrollViewer"
                              VerticalScrollMode="Auto"
                              Visibility="{Binding HasSession, Converter={StaticResource BoolToVisible}}">
                    <StackPanel x:Name="ConversationPanel"
                                Spacing="12" Margin="16,8">

                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlanningMessageViewModel">
                                    <Grid Margin="0,0,0,12">

                                        <!-- User message -->
                                        <Border Style="{StaticResource UserBubbleStyle}"
                                                Visibility="{Binding IsUser, Converter={StaticResource BoolToVisible}}">
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="White"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyTextBlockStyle}" />
                                        </Border>

                                        <!-- AI message -->
                                        <Border Style="{StaticResource AiBubbleStyle}"
                                                Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisible}}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyTextBlockStyle}" />
                                                <!-- Filtered notice -->
                                                <TextBlock Text="(Implementation details filtered — please rephrase in business terms)"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           FontStyle="Italic"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Visibility="{Binding WasFiltered, Converter={StaticResource BoolToVisible}}"
                                                           TextWrapping="Wrap" />
                                                <!-- Streaming indicator -->
                                                <ProgressRing IsActive="{Binding IsStreaming}"
                                                              Width="16" Height="16"
                                                              Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVisible}}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- DSL Output Panel -->
                <Expander Grid.Row="2"
                          x:Name="DslExpander"
                          IsExpanded="{Binding IsDslPanelOpen, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Margin="16,4"
                          Visibility="{Binding HasSession, Converter={StaticResource BoolToVisible}}">
                    <Expander.Header>
                        <TextBlock Text="{Binding DslPanelTitle}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </Expander.Header>

                    <StackPanel Spacing="8">
                        <!-- YAML content (monospace, dark) -->
                        <ScrollViewer MaxHeight="280" VerticalScrollMode="Auto">
                            <Border Background="#1E1E1E" CornerRadius="4" Padding="12">
                                <TextBlock Text="{Binding DslContent}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="#CCCCCC"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True" />
                            </Border>
                        </ScrollViewer>

                        <!-- DSL actions -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Lock DSL"
                                    Click="LockDsl_Click"
                                    Background="#107C10" Foreground="White"
                                    Visibility="{Binding HasDraftDsl, Converter={StaticResource BoolToVisible}}" />
                            <Button Content="Discard Draft"
                                    Click="DiscardDraft_Click"
                                    Visibility="{Binding HasDraftDsl, Converter={StaticResource BoolToVisible}}" />
                            <Button Content="Export as YAML"
                                    Click="ExportDsl_Click" />
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- Turn limit banners -->
                <StackPanel Grid.Row="3" Margin="16,4"
                            Visibility="{Binding HasSession, Converter={StaticResource BoolToVisible}}">

                    <!-- Soft warning (25 turns) -->
                    <Border Background="#FFB900" CornerRadius="6" Padding="12,8" Margin="0,0,0,4"
                            Visibility="{Binding ShowSoftWarning, Converter={StaticResource BoolToVisible}}">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="This phase has had 25+ exchanges. Ready to generate the DSL and move on?"
                                           TextWrapping="Wrap"
                                           Foreground="#3D2B00"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                <Button Content="Generate DSL" Click="GenerateDsl_Click"
                                        Background="#0078D4" Foreground="White" />
                                <Button Content="Dismiss" Click="DismissSoftWarning_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Hard limit (40 turns) -->
                    <Border Background="#D13438" CornerRadius="6" Padding="12,8"
                            Visibility="{Binding ShowHardLimit, Converter={StaticResource BoolToVisible}}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="HARD LIMIT REACHED"
                                       Foreground="White"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="This phase has reached the maximum of 40 exchanges. Generate the DSL now or start a new session."
                                       TextWrapping="Wrap"
                                       Foreground="White"
                                       Style="{StaticResource BodyTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Generate DSL" Click="GenerateDsl_Click"
                                        Background="#107C10" Foreground="White" />
                                <Button Content="New Session"  Click="NewSession_Click"
                                        Background="#0078D4" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Input area -->
                <Grid Grid.Row="4" Margin="16,4,16,12"
                      Visibility="{Binding HasSession, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="MessageInputBox"
                             Text="{Binding MessageInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Type your message here... (Ctrl+Enter to send)"
                             AcceptsReturn="True"
                             MinHeight="64" MaxHeight="200"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0,0,8,0"
                             IsEnabled="{Binding ShowHardLimit, Converter={StaticResource InverseBool}}"
                             KeyDown="MessageInput_KeyDown" />

                    <StackPanel Grid.Column="1" Spacing="4">
                        <Button x:Name="SendButton"
                                Content="Send"
                                Click="Send_Click"
                                IsEnabled="{Binding IsLlmResponding, Converter={StaticResource InverseBool}}"
                                Width="72" Height="44" />
                        <Button Content="Cancel"
                                Click="Cancel_Click"
                                Width="72"
                                Visibility="{Binding IsLlmResponding, Converter={StaticResource BoolToVisible}}" />
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Page>
