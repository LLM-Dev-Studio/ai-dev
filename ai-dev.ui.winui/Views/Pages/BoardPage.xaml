<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.BoardPage"
    x:Name="BoardRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:PriorityColorConverter x:Key="PriorityColor" />
        <conv:PriorityTextConverter x:Key="PriorityText" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid>
        <!-- Board + task dialog overlay -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Board" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Track tasks across your workflow"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <ProgressRing Grid.Row="1"
                          IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Kanban columns -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
                <ItemsControl ItemsSource="{Binding Columns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" MinHeight="420" Margin="0,0,16,0" Padding="12" CornerRadius="8"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Stretch">
                                <StackPanel>
                                    <!-- Column header -->
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Column.Title}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <Border CornerRadius="4" Padding="5,1"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                                <TextBlock Text="{Binding Tasks.Count}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                            <Button Content="Clear"
                                                    Visibility="{Binding IsDone, Converter={StaticResource BoolToVisible}}"
                                                    Click="ClearCompleted_Click"
                                                    Padding="8,4" />
                                            <Button Content="+ Add"
                                                    Tag="{Binding Column.Id}"
                                                    Click="AddTask_Click"
                                                    Padding="8,4" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Tasks -->
                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8" Padding="10" CornerRadius="6"
                                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Title}"
                                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,4" />

                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding Description}"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="2"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,0,8"
                                                                   Visibility="{Binding Description, Converter={StaticResource NullToVisible}}" />

                                                        <Grid Grid.Row="2">
                                                            <Border Background="{Binding Priority, Converter={StaticResource PriorityColor}}"
                                                                    CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityText}}"
                                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                                           Foreground="White" />
                                                            </Border>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                                                <Button Content="Transcript"
                                                                        Tag="{Binding}"
                                                                        Click="TaskTranscript_Click"
                                                                        Padding="6,2" />
                                                                <Button Content="Edit"
                                                                        Tag="{Binding}"
                                                                        Click="EditTask_Click"
                                                                        Padding="6,2" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>

