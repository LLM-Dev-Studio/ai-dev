<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.BoardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:PriorityColorConverter x:Key="PriorityColor" />
        <conv:PriorityTextConverter x:Key="PriorityText" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid>
        <!-- Board + task dialog overlay -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Board" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Track tasks across your workflow"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <ProgressRing Grid.Row="1"
                          IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Kanban columns -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
                <ItemsControl ItemsSource="{Binding Columns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" Margin="0,0,16,0" Padding="12" CornerRadius="8"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Top">
                                <StackPanel>
                                    <!-- Column header -->
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Column.Title}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <Border CornerRadius="4" Padding="5,1"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                                <TextBlock Text="{Binding Tasks.Count}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                        </StackPanel>
                                        <Button Content="+ Add"
                                                HorizontalAlignment="Right"
                                                Tag="{Binding Column.Id}"
                                                Click="AddTask_Click"
                                                Padding="8,4" />
                                    </Grid>

                                    <!-- Tasks -->
                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8" Padding="10" CornerRadius="6"
                                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Title}"
                                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,4" />

                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding Description}"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="2"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,0,8"
                                                                   Visibility="{Binding Description, Converter={StaticResource NullToVisible}}" />

                                                        <Grid Grid.Row="2">
                                                            <Border Background="{Binding Priority, Converter={StaticResource PriorityColor}}"
                                                                    CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityText}}"
                                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                                           Foreground="White" />
                                                            </Border>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                                                <Button Content="Edit"
                                                                        Tag="{Binding}"
                                                                        Click="EditTask_Click"
                                                                        Padding="6,2" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Task dialog overlay -->
        <Grid Visibility="{Binding ShowTaskDialog, Converter={StaticResource BoolToVisible}}"
              Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
              Opacity="0.5"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="520" Padding="24" CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Visibility="{Binding ShowTaskDialog, Converter={StaticResource BoolToVisible}}">
            <StackPanel Spacing="12">

                <TextBlock Text="{Binding DialogTitle}" Style="{StaticResource SubtitleTextBlockStyle}" />

                <!-- Title + Enhance -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Title" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding TaskTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Task title" />
                        <Button Grid.Column="1"
                                Content="✨ Enhance"
                                Command="{Binding EnhanceCommand}"
                                IsEnabled="{Binding IsEnhancing, Converter={StaticResource InverseBool}}" />
                    </Grid>
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{Binding IsEnhancing, Converter={StaticResource BoolToVisible}}" />
                </StackPanel>

                <!-- Description -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Description" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding TaskDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             PlaceholderText="Optional details, acceptance criteria…" />
                </StackPanel>

                <!-- Priority + Column -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Priority" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="PriorityCombo"
                                  HorizontalAlignment="Stretch"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding TaskPriority, Mode=TwoWay}">
                            <ComboBoxItem Content="Low" Tag="low" />
                            <ComboBoxItem Content="Normal" Tag="normal" />
                            <ComboBoxItem Content="High" Tag="high" />
                            <ComboBoxItem Content="Critical" Tag="critical" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Assignee" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="AssigneeCombo"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding AssigneeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding SelectedAssigneeOption, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>

                <!-- Error -->
                <TextBlock Text="{Binding TaskError}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           Visibility="{Binding TaskError, Converter={StaticResource NullToVisible}}"
                           Style="{StaticResource CaptionTextBlockStyle}" />

                <!-- Footer buttons -->
                <Grid Margin="0,4,0,0">
                    <Button Content="Delete task"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding ShowTaskDialog, Converter={StaticResource BoolToVisible}}"
                            Click="DeleteTask_Click" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Cancel"
                                Command="{Binding CloseTaskDialogCommand}" />
                        <Button Content="{Binding DialogTitle}"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding SaveTaskCommand}"
                                IsEnabled="{Binding IsSavingTask, Converter={StaticResource InverseBool}}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>

