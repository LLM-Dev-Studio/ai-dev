<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.TaskTranscriptPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Back to Board" Command="{Binding GoBackCommand}" Margin="0,0,0,12" />

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Task Transcript" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{Binding Task.Title}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" Visibility="{Binding Task, Converter={StaticResource NullToVisible}}" />
            <TextBlock Text="{Binding ErrorText}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Style="{StaticResource BodyTextBlockStyle}" Visibility="{Binding ErrorText, Converter={StaticResource NullToVisible}}" />
        </StackPanel>

        <ProgressRing Grid.Row="2"
                      IsActive="{Binding IsLoading}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <ListView Grid.Row="2"
                  ItemsSource="{Binding Messages}"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8" Padding="12" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Re}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="From: " />
                                <Run Text="{Binding From}" />
                                <Run Text="  →  " />
                                <Run Text="{Binding To}" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="When: " />
                                <Run Text="{Binding Date}" />
                                <Run Text="  · Type: " />
                                <Run Text="{Binding Type}" />
                            </TextBlock>
                            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
