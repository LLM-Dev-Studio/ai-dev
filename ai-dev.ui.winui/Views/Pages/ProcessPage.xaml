<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.ProcessPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Margin="24">
        <StackPanel Spacing="24">

            <StackPanel>
                <TextBlock Text="Process" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="How work flows through this project."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Current Workflow -->
            <StackPanel Spacing="10">
                <TextBlock Text="Current Workflow" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"
                                   Text="Work flows through this project via a filesystem-based message bus. Agents run as isolated sessions and communicate by writing Markdown files to each other's inboxes. The dispatcher watches for new inbox files and launches the relevant agent automatically." />
                        <StackPanel Spacing="4">
                            <TextBlock Text="1.  A human sends a brief to the PM agent's inbox (or creates board tasks directly)." Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                            <TextBlock Text="2.  The PM decomposes the brief into tasks on the board and dispatches work to agents." Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                            <TextBlock Text="3.  Each agent processes its inbox, performs work, and messages the next agent in the chain." Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                            <TextBlock Text="4.  Before any task moves to Done: security review (Riley) and QA (Sage) run in parallel." Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                            <TextBlock Text="5.  On completion the PM sends a report to the human inbox." Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Trigger model -->
            <StackPanel Spacing="10">
                <TextBlock Text="How Agent Launches Are Triggered" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Grid.Column="0" Margin="0,0,6,6" CornerRadius="8" Padding="14"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="FileSystemWatcher" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Fires immediately when a *.md file is created or renamed in an agent's inbox. Zero-latency dispatch for most messages." />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Margin="6,0,0,6" CornerRadius="8" Padding="14"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="10-Second Poll" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Safety net that scans all inboxes every 10 seconds. Catches anything the FSW missed due to buffer overflow, OS error, or race conditions." />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" Margin="0,0,6,0" CornerRadius="8" Padding="14"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Overwatch (every 5 min)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Scans the board for tasks stalled &gt;30 min. Nudges the assigned agent or raises a decision for unassigned tasks." />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Margin="6,0,0,0" CornerRadius="8" Padding="14"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Re-launch on new inbox" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="If messages arrive while an agent is running, the runner automatically re-launches the agent after the current session exits." />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Quality gate -->
            <StackPanel Spacing="10">
                <TextBlock Text="Quality Gate" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"
                                   Text="Before any task moves to done, two checks must pass in parallel:" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0,0,6,0" CornerRadius="6" Padding="12"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Security Review — Riley" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="Checks for OWASP top-10 issues, dependency vulnerabilities, secrets in code, and auth/authz problems." />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="6,0,0,0" CornerRadius="6" Padding="12"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="QA Review — Sage" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="Verifies acceptance criteria, test coverage, and regression risk before marking a task complete." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
