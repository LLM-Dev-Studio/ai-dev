<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.TranscriptPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Back button -->
        <Button Grid.Row="0" Content="← Back to Agent" Command="{Binding GoBackCommand}" Margin="0,0,0,16" />

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Dates list -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Transcript"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,4" />

            <TextBlock Grid.Row="1"
                       Text="{Binding Agent.Name}"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,12" />

            <ProgressRing Grid.Row="2"
                          IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                          HorizontalAlignment="Center" />

            <ListView Grid.Row="2"
                      ItemsSource="{Binding Dates}"
                      SelectedItem="{Binding SelectedDate, Mode=TwoWay}"
                      SelectionChanged="Date_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Value}" Padding="4" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Transcript content -->
        <Border Grid.Column="1" Padding="16" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Visibility="{Binding SelectedDate, Converter={StaticResource NullToVisible}}">
            <ScrollViewer>
                <TextBlock Text="{Binding TranscriptContent}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12"
                           Style="{StaticResource BodyTextBlockStyle}" />
            </ScrollViewer>
        </Border>
        </Grid>
    </Grid>
</Page>
