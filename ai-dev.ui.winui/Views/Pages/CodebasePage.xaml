<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.CodebasePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <ProgressRing IsActive="{Binding IsLoading}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
            <StackPanel Spacing="16">
                <TextBlock Text="Codebase" Style="{StaticResource TitleTextBlockStyle}" />

                <!-- Init success banner -->
                <Border CornerRadius="8" Padding="12"
                        Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                        Visibility="{Binding InitDone, Converter={StaticResource BoolToVisible}}">
                    <TextBlock Text="Codebase initialized successfully." Style="{StaticResource BodyTextBlockStyle}" />
                </Border>

                <!-- Not-initialized panel -->
                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                        BorderThickness="1"
                        Visibility="{Binding CodebaseInitialized, Converter={StaticResource InverseBoolToVisible}}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Codebase not initialized" Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <!-- Mode selector -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton x:Name="CreateRadio" Content="Create new" GroupName="InitMode"
                                         IsChecked="True" Checked="CreateMode_Checked" />
                            <RadioButton x:Name="LinkRadio" Content="Link existing" GroupName="InitMode"
                                         Checked="LinkMode_Checked" />
                        </StackPanel>

                        <!-- Custom path input (shown for link mode) -->
                        <TextBox PlaceholderText="Absolute path to existing codebase"
                                 Text="{Binding CustomPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Visibility="{Binding IsLinkMode, Converter={StaticResource BoolToVisible}}" />

                        <TextBlock Text="{Binding InitError}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   Visibility="{Binding InitError, Converter={StaticResource NullToVisible}}" />

                        <Button Content="Initialize"
                                Command="{Binding InitializeCommand}"
                                IsEnabled="{Binding IsInitializing, Converter={StaticResource InverseBoolToVisible}}" />
                    </StackPanel>
                </Border>

                <!-- Project info card -->
                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Project Info" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project dir"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProjectDir}"
                                       Style="{StaticResource CaptionTextBlockStyle}" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Codebase status"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="CodebaseStatusText" Grid.Row="1" Grid.Column="1"
                                       Style="{StaticResource CaptionTextBlockStyle}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Codebase path"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{Binding CodebasePath, Converter={StaticResource NullToVisible}}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CodebasePath}"
                                       Style="{StaticResource CaptionTextBlockStyle}" TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding CodebasePath, Converter={StaticResource NullToVisible}}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Git repository"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{Binding CodebaseInitialized, Converter={StaticResource BoolToVisible}}" />
                            <TextBlock x:Name="IsGitRepoText" Grid.Row="3" Grid.Column="1"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Visibility="{Binding CodebaseInitialized, Converter={StaticResource BoolToVisible}}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Commit log -->
                <StackPanel Spacing="12"
                            Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisible}}">
                    <TextBlock Text="Commits" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <Grid>
                        <!-- Commit list -->
                        <ListView x:Name="CommitList" ItemsSource="{Binding Commits}"
                                  SelectionMode="None"
                                  Visibility="{Binding SelectedCommit, Converter={StaticResource NullToVisible}, ConverterParameter=inverse}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" CornerRadius="6" Margin="0,0,0,4"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Subject}" Style="{StaticResource BodyTextBlockStyle}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{Binding ShortHash}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{Binding Author}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="View" Tag="{Binding Hash}"
                                                    Click="SelectCommit_Click"
                                                    Style="{StaticResource DefaultButtonStyle}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Commit detail panel -->
                        <Border x:Name="CommitDetailPanel"
                                Padding="16" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Visibility="{Binding SelectedCommit, Converter={StaticResource NullToVisible}}">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <TextBlock Text="{Binding SelectedCommit.Commit.Subject}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <Button Content="← Back" HorizontalAlignment="Right"
                                            Command="{Binding CloseDetailCommand}" />
                                </Grid>
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{Binding SelectedCommit.Commit.Hash}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding SelectedCommit.Commit.Author}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding SelectedCommit.Commit.Date}" />
                                </TextBlock>
                                <TextBlock Text="{Binding SelectedCommit.Body}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Visibility="{Binding SelectedCommit.Body, Converter={StaticResource NullToVisible}}" />
                                <ScrollViewer MaxHeight="400" HorizontalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding SelectedCommit.Diff}"
                                               FontFamily="Consolas" FontSize="11"
                                               TextWrapping="NoWrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
