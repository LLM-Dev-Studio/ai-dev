<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AiDev.WinUI.Views.Pages.MessagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:AiDev.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: message list -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Messages"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,12" />

            <ToggleSwitch Grid.Row="1"
                          Header="Show processed"
                          IsOn="{Binding ShowProcessed, Mode=TwoWay}"
                          Margin="0,0,0,12"
                          Toggled="ShowProcessed_Toggled" />

            <ProgressRing Grid.Row="2"
                          IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                          HorizontalAlignment="Center" />

            <ListView Grid.Row="2"
                      ItemsSource="{Binding Messages}"
                      SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}"
                      SelectionChanged="Messages_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="4" Spacing="4">
                            <TextBlock Text="{Binding Subject}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding From}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right: message detail -->
        <Border Grid.Column="1" Padding="20" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Visibility="{Binding SelectedMessage, Converter={StaticResource NullToVisible}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding SelectedMessage.Subject}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,4" />

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="From: " />
                        <Run Text="{Binding SelectedMessage.From}" />
                    </TextBlock>
                </StackPanel>

                <ScrollViewer Grid.Row="2">
                    <TextBlock Text="{Binding SelectedMessage.Body}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyTextBlockStyle}" />
                </ScrollViewer>

                <Button Grid.Row="3"
                        Content="Mark Processed"
                        Margin="0,16,0,0"
                        Click="MarkProcessed_Click" />
            </Grid>
        </Border>
    </Grid>
</Page>
