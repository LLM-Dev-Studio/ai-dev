@{
    var (dotClass, textClass) = Status switch
    {
        "running" => ("bg-emerald-400 animate-pulse", "text-emerald-400"),
        "error"   => ("bg-red-400", "text-red-400"),
        _         => ("bg-zinc-500", "text-zinc-400"),
    };
    var label = Status ?? "idle";
}

<span class="inline-flex items-center gap-1.5 text-xs font-medium px-2 py-0.5 rounded-full border border-border bg-secondary">
    <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
    <span class="@textClass">@label</span>
</span>

@code {
    [Parameter] public string? Status { get; set; }
}
