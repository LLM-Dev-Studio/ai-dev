<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 @Class">
    @for (int i = 0; i < Count; i++)
    {
        <div class="rounded-lg border border-border bg-card p-5 space-y-3 animate-pulse">
            <div class="flex justify-between items-start">
                <div class="space-y-1.5">
                    <div class="h-4 w-28 bg-muted rounded"></div>
                    <div class="h-3 w-20 bg-muted/60 rounded"></div>
                </div>
                <div class="flex gap-2">
                    <div class="h-5 w-14 bg-muted rounded-full"></div>
                    <div class="h-5 w-16 bg-muted rounded-full"></div>
                </div>
            </div>
            <div class="space-y-2 pt-1">
                <div class="flex justify-between">
                    <div class="h-3 w-16 bg-muted/60 rounded"></div>
                    <div class="h-3 w-20 bg-muted/40 rounded"></div>
                </div>
                <div class="flex justify-between">
                    <div class="h-3 w-12 bg-muted/60 rounded"></div>
                    <div class="h-3 w-8 bg-muted/40 rounded"></div>
                </div>
                <div class="flex justify-between">
                    <div class="h-3 w-24 bg-muted/60 rounded"></div>
                    <div class="h-3 w-12 bg-muted/40 rounded"></div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Count { get; set; } = 6;
    [Parameter] public string Class { get; set; } = string.Empty;
}
