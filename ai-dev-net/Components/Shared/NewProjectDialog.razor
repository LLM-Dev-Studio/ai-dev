@inject AgentTemplatesService TemplatesService

<div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-card border border-border rounded-lg w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-5">
            <p class="text-sm font-semibold text-foreground">New Project</p>
            <button @onclick="OnClose" class="p-1 text-muted-foreground hover:text-foreground transition-colors">
                <SvgIcon Name="x" Class="w-4 h-4" />
            </button>
        </div>

        <div class="space-y-3">
            <div>
                <label class="block text-xs text-muted-foreground mb-1">Project name</label>
                <input value="@name"
                       @oninput="OnNameInput"
                       placeholder="My Project"
                       class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div>
                <label class="block text-xs text-muted-foreground mb-1">Slug</label>
                <input value="@slug"
                       @oninput="e => slug = e.Value?.ToString() ?? string.Empty"
                       placeholder="my-project"
                       class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                <p class="text-xs text-muted-foreground/60 mt-1">Used as the folder name. Lowercase letters, digits, and hyphens only.</p>
            </div>
            <div>
                <label class="block text-xs text-muted-foreground mb-1">
                    Description
                    <span class="opacity-60 ml-1">(optional)</span>
                </label>
                <input value="@description"
                       @oninput="e => description = e.Value?.ToString() ?? string.Empty"
                       placeholder="What is this project about?"
                       class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            <div>
                <label class="block text-xs text-muted-foreground mb-1">
                    Codebase path
                    <span class="opacity-60 ml-1">(optional)</span>
                </label>
                <input value="@codebasePath"
                       @oninput="e => codebasePath = e.Value?.ToString() ?? string.Empty"
                       placeholder="C:\path\to\your\code"
                       class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                <p class="text-xs text-muted-foreground/60 mt-1">Absolute path to the codebase agents will work on.</p>
            </div>

            @if (templates.Count > 0)
            {
                <div>
                    <label class="block text-xs text-muted-foreground mb-2">
                        Agents
                        <span class="opacity-60 ml-1">(select templates to add)</span>
                    </label>
                    <div class="space-y-1.5 max-h-48 overflow-y-auto pr-1">
                        @foreach (var t in templates)
                        {
                            var isSelected = selectedTemplateSlugs.Contains(t.Slug);
                            <label class="flex items-start gap-2.5 p-2.5 rounded-md border cursor-pointer transition-colors @(isSelected ? "border-primary/50 bg-primary/5" : "border-border hover:border-border/80")">
                                <input type="checkbox"
                                       checked="@isSelected"
                                       @onchange="() => ToggleTemplate(t.Slug, t.Name)"
                                       class="mt-0.5 flex-shrink-0 accent-primary" />
                                <div class="min-w-0">
                                    <p class="text-xs font-medium text-foreground">@t.Name</p>
                                    @if (!string.IsNullOrEmpty(t.Description))
                                    {
                                        <p class="text-xs text-muted-foreground truncate mt-0.5">@t.Description</p>
                                    }
                                    <p class="text-xs text-muted-foreground/60 mt-0.5 font-mono">@t.Slug · @t.Model</p>
                                </div>
                            </label>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <p class="text-xs text-destructive">@error</p>
            }
        </div>

        <div class="flex justify-end gap-3 mt-5">
            <button @onclick="OnClose"
                    class="text-xs px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground transition-colors">
                Cancel
            </button>
            <button @onclick="Create"
                    disabled="@saving"
                    class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 disabled:opacity-50 transition-colors">
                <SvgIcon Name="plus" Class="w-3 h-3" />
                @(saving ? "Creating…" : "Create project")
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Func<NewProjectRequest, Task<string?>> OnCreated { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback OnClose { get; set; }

    private string name = string.Empty;
    private string slug = string.Empty;
    private string description = string.Empty;
    private string codebasePath = string.Empty;
    private readonly HashSet<string> selectedTemplateSlugs = [];
    private List<AgentTemplate> templates = [];
    private bool saving;
    private string error = string.Empty;

    protected override void OnInitialized()
    {
        templates = TemplatesService.ListTemplates();
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        name = e.Value?.ToString() ?? string.Empty;
        slug = new string(name.ToLowerInvariant()
            .Replace(' ', '-')
            .Where(c => char.IsLetterOrDigit(c) || c == '-')
            .ToArray())
            .Trim('-');
    }

    private readonly Dictionary<string, string> selectedTemplates = [];

    private void ToggleTemplate(string templateSlug, string templateName)
    {
        if (!selectedTemplateSlugs.Add(templateSlug))
        {
            selectedTemplateSlugs.Remove(templateSlug);
            selectedTemplates.Remove(templateSlug);
        }
        else
        {
            selectedTemplates[templateSlug] = templateName;
        }
    }

    private async Task Create()
    {
        error = string.Empty;
        if (string.IsNullOrWhiteSpace(name)) { error = "Project name is required."; return; }
        if (string.IsNullOrWhiteSpace(slug)) { error = "Slug is required."; return; }

        saving = true;
        try
        {
            var serverError = await OnCreated(new NewProjectRequest(
                slug, name, description,
                string.IsNullOrWhiteSpace(codebasePath) ? null : codebasePath,
                new Dictionary<string, string>(selectedTemplates)));
            if (serverError != null)
                error = serverError;
        }
        finally
        {
            saving = false;
        }
    }

    /// <param name="SelectedTemplates">Map of template slug → display name for agents to create.</param>
    public record NewProjectRequest(
        string Slug,
        string Name,
        string Description,
        string? CodebasePath,
        Dictionary<string, string> SelectedTemplates);
}
