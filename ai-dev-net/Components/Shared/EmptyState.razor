<div class="flex flex-col items-center justify-center py-16 text-center @ClassName">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <div class="text-muted-foreground opacity-40 mb-3">
            <SvgIcon Name="@Icon" />
        </div>
    }
    <p class="text-sm font-medium text-muted-foreground">@Title</p>
    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="text-xs text-muted-foreground opacity-60 mt-1 max-w-sm">@Description</p>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; }
    [Parameter] public string Title { get; set; }
    [Parameter] public string Description { get; set; }
    [Parameter] public string ClassName { get; set; }
}
