@using AiDev.Features.Agent
@using AiDev.Executors
@using AiDev.Services
@inject IJSRuntime JS
@inject IModelRegistry ModelRegistry
@inject ExecutorHealthMonitor ExecutorHealthMonitor
@implements IDisposable

<div class="rounded-lg border border-border bg-card">
    <div class="flex items-center justify-between px-5 py-4">
        <button class="flex-1 text-left" @onclick="ToggleExpanded">
            <p class="text-sm font-semibold text-foreground">@Template.Name</p>
            <p class="text-xs text-muted-foreground mt-0.5">
                <span class="font-mono">@Template.Role</span>
                @(" · ")
                <span class="font-mono">@(string.IsNullOrEmpty(Template.Executor) ? "claude" : Template.Executor)</span>
                @(" · ")
                <span class="font-mono">@Template.Model</span>
                @if (!string.IsNullOrEmpty(Template.Description))
                {
                    @($" · {Template.Description}")
                }
            </p>
        </button>
        <div class="flex items-center gap-2">
            <button @onclick="Delete"
                    class="p-1.5 text-muted-foreground hover:text-destructive transition-colors"
                    title="Delete template">
                <SvgIcon Name="trash-2" Class="w-3.5 h-3.5" />
            </button>
            <button @onclick="ToggleExpanded" class="p-1.5 text-muted-foreground">
                <SvgIcon Name="@(expanded ? "chevron-up" : "chevron-down")" Class="w-4 h-4" />
            </button>
        </div>
    </div>

    @if (expanded)
    {
        <div class="px-5 pb-5 border-t border-border space-y-4 pt-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Name</label>
                    <input value="@draft.Name"
                           @oninput="e => SetName(e.Value?.ToString())"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Role</label>
                    <select value="@draft.Role"
                            @onchange="e => SetRole(e.Value?.ToString())"
                            class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                        @foreach (var role in Roles)
                        {
                            <option value="@role" selected="@(draft.Role == role)">@role</option>
                        }
                        @if (!Roles.Contains(draft.Role) && !string.IsNullOrEmpty(draft.Role))
                        {
                            <option value="@draft.Role" selected>@draft.Role</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Executor</label>
                    <select value="@draftExecutor"
                            @onchange="e => SetExecutor(e.Value?.ToString())"
                            class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                        @foreach (var opt in executorOptions)
                        {
                            <option value="@opt.Name" selected="@(draftExecutor == opt.Name)">
                                @opt.DisplayName @(opt.Healthy ? "" : "(offline)")
                            </option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Model</label>
                    @{
                        var scopedModels = ModelRegistry.GetModelsForExecutor(draftExecutor);
                    }
                    @if (scopedModels.Count > 0)
                    {
                        <select value="@draft.Model"
                                @onchange="e => SetModel(e.Value?.ToString())"
                                class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                            @foreach (var m in scopedModels)
                            {
                                var badges = (m.Capabilities.HasFlag(ModelCapabilities.ToolCalling) ? "🔧" : "")
                                           + (m.Capabilities.HasFlag(ModelCapabilities.Vision) ? "👁" : "")
                                           + (m.Capabilities.HasFlag(ModelCapabilities.Reasoning) ? "🧠" : "");
                                <option value="@m.Id" selected="@(draft.Model == m.Id)">
                                    @m.DisplayName@(badges.Length > 0 ? $" {badges}" : "")
                                </option>
                            }
                        </select>
                    }
                    else
                    {
                        <input value="@draft.Model"
                               @oninput="e => SetModel(e.Value?.ToString())"
                               placeholder="e.g. llama3.2"
                               class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                    }
                </div>
                <div class="col-span-2">
                    <label class="block text-xs text-muted-foreground mb-1">Description</label>
                    <input value="@draft.Description"
                           @oninput="e => SetDescription(e.Value?.ToString())"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
                @{
                    var availableSkills = ExecutorHealthMonitor.GetExecutorHealth()
                        .Where(e => e.Executor.Name == draftExecutor)
                        .SelectMany(e => e.Executor.AvailableSkills)
                        .ToList();
                }
                @if (availableSkills.Count > 0)
                {
                    <div class="col-span-2">
                        <label class="block text-xs text-muted-foreground mb-1">Skills</label>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var skill in availableSkills)
                            {
                                var isChecked = draftSkills.Contains(skill.Key);
                                <label class="flex items-center gap-1.5 text-sm cursor-pointer" title="@skill.Description">
                                    <input type="checkbox" checked="@isChecked"
                                           @onchange="@(e => { if ((bool?)e.Value == true) draftSkills.Add(skill.Key); else draftSkills.Remove(skill.Key); })"
                                           class="accent-primary" />
                                    @skill.DisplayName
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
            @{
                var templateModelDescriptor = ModelRegistry.GetModelsForExecutor(draftExecutor)
                    .FirstOrDefault(m => m.Id == draft.Model);
                var templateModelSupportsThinking = templateModelDescriptor?.Capabilities.HasFlag(ModelCapabilities.Reasoning) == true;
            }
            @if (templateModelSupportsThinking)
            {
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Thinking level 🧠</label>
                    <select value="@draftThinkingLevel.Serialize()"
                            @onchange="e => draftThinkingLevel = ThinkingLevelExtensions.Parse(e.Value?.ToString())"
                            class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                        @foreach (var level in Enum.GetValues<ThinkingLevel>())
                        {
                            <option value="@level.Serialize()" selected="@(draftThinkingLevel == level)">@level.ToDisplayName()</option>
                        }
                    </select>
                </div>
            }

            <div>
                <label class="block text-xs text-muted-foreground mb-1">
                    Instructions (CLAUDE.md)
                    <span class="ml-2 opacity-60">— leave blank to generate from role at agent-creation time</span>
                </label>
                <textarea id="@textareaId"
                          @oninput="OnContentInput"
                          placeholder="Leave blank to auto-generate from role template…"
                          class="w-full rounded-md border border-border bg-background px-3 py-2 text-xs font-mono text-foreground/90 leading-relaxed resize-none focus:outline-none focus:ring-1 focus:ring-ring min-h-[120px]"
                          spellcheck="false">@draft.Content</textarea>
            </div>

            <div class="flex items-center justify-end gap-3">
                @if (saveStatus == SaveStatus.Saved)
                {
                    <span class="text-xs text-green-500">Saved</span>
                }
                else if (saveStatus == SaveStatus.Error)
                {
                    <span class="text-xs text-destructive">Error</span>
                }
                <button @onclick="Save"
                        disabled="@(saving || !IsDirty)"
                        class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 disabled:opacity-50 transition-colors">
                    <SvgIcon Name="save" Class="w-3 h-3" />
                    @(saving ? "Saving…" : "Save")
                </button>
            </div>
        </div>
    }
</div>

@code {
    private static readonly List<string> Roles =
    [
        "analyst", "architect", "designer", "developer", "devops",
        "growth-marketing", "guard", "process-evo", "project-manager", "qa", "generic"
    ];

    private sealed record ExecutorOption(string Name, string DisplayName, bool Healthy);

    [Parameter, EditorRequired] public AgentTemplate Template { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<AgentTemplate> OnSave { get; set; }
    [Parameter, EditorRequired] public EventCallback<string> OnDelete { get; set; }

    private AgentTemplate draft = default!;
    private string draftExecutor = string.Empty;
    private HashSet<string> draftSkills = [];
    private ThinkingLevel draftThinkingLevel = ThinkingLevel.Off;
    private List<ExecutorOption> executorOptions = [];
    private bool expanded;
    private bool saving;
    private SaveStatus saveStatus = SaveStatus.Idle;
    private string textareaId = string.Empty;
    private IDisposable? _healthChangedSubscription;

    protected override void OnInitialized()
    {
        InitializeDraft();
        textareaId = $"ta-{Template.Slug}";
        _healthChangedSubscription = ExecutorHealthMonitor.SubscribeChanged(OnHealthChanged);
    }

    public void Dispose() => _healthChangedSubscription?.Dispose();

    private void OnHealthChanged()
    {
        RefreshExecutorOptions();
        InvokeAsync(StateHasChanged);
    }

    private void InitializeDraft()
    {
        draft = new AgentTemplate
        {
            Slug = Template.Slug,
            Name = Template.Name,
            Role = Template.Role,
            Model = Template.Model,
            Description = Template.Description,
            Content = Template.Content,
        };
        draftExecutor = string.IsNullOrWhiteSpace(Template.Executor)
            ? "claude"
            : Template.Executor;
        draftSkills = [.. Template.Skills ?? []];
        draftThinkingLevel = Template.ThinkingLevel;
        RefreshExecutorOptions();
    }

    private void RefreshExecutorOptions()
    {
        executorOptions = ExecutorHealthMonitor.GetExecutorHealth()
            .Select(e => new ExecutorOption(e.Executor.Name, e.Executor.DisplayName, e.Health.IsHealthy))
            .DistinctBy(o => o.Name)
            .OrderBy(o => o.DisplayName)
            .ToList();
    }

    private bool IsDirty =>
        draft.Name != Template.Name ||
        draft.Role != Template.Role ||
        draft.Model != Template.Model ||
        draft.Description != Template.Description ||
        draft.Content != Template.Content ||
        draftExecutor != (string.IsNullOrWhiteSpace(Template.Executor) ? "claude" : Template.Executor) ||
        draftThinkingLevel != Template.ThinkingLevel ||
        !draftSkills.SetEquals(Template.Skills ?? []);

    private void ToggleExpanded() => expanded = !expanded;

    private void SetName(string? v) => draft.Name = v ?? string.Empty;
    private void SetRole(string? v) => draft.Role = v ?? string.Empty;
    private void SetDescription(string? v) => draft.Description = v ?? string.Empty;

    private void SetExecutor(string? v)
    {
        var newExecutor = v ?? "claude";
        if (newExecutor == draftExecutor) return;
        draftExecutor = newExecutor;
        // Reset model to first available for this executor (or clear if executor is dynamic/offline).
        var models = ModelRegistry.GetModelsForExecutor(draftExecutor);
        draft.Model = models.Count > 0 ? models[0].Id : string.Empty;
        // Clear skills — they are executor-scoped and the old keys are not valid here.
        draftSkills.Clear();
    }

    private void SetModel(string? v) => draft.Model = v ?? string.Empty;

    private async Task OnContentInput(ChangeEventArgs e)
    {
        draft.Content = e.Value?.ToString() ?? string.Empty;
        await JS.InvokeVoidAsync("autoResizeById", textareaId);
    }

    private async Task Save()
    {
        saving = true;
        saveStatus = SaveStatus.Idle;
        try
        {
            draft.Executor = draftExecutor;
            draft.Skills = [.. draftSkills];
            draft.ThinkingLevel = draftThinkingLevel;
            await OnSave.InvokeAsync(draft);
            saveStatus = SaveStatus.Saved;
            _ = Task.Delay(2000).ContinueWith(_ =>
            {
                saveStatus = SaveStatus.Idle;
                InvokeAsync(StateHasChanged);
            });
        }
        catch
        {
            saveStatus = SaveStatus.Error;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task Delete() => await OnDelete.InvokeAsync(Template.Slug);

    private enum SaveStatus { Idle, Saved, Error }
}
