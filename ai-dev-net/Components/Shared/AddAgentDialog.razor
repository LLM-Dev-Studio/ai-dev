@using AiDev.Features.Agent
@using AiDev.Models.Types
@inject AgentTemplatesService TemplatesService
@inject AgentService AgentService

<div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-card border border-border rounded-lg w-full max-w-lg p-6">
        <div class="flex items-center justify-between mb-5">
            <p class="text-sm font-semibold text-foreground">Add Agent</p>
            <button @onclick="OnClose" class="p-1 text-muted-foreground hover:text-foreground transition-colors">
                <SvgIcon Name="x" Class="w-4 h-4" />
            </button>
        </div>

        @if (templates.Count > 0)
        {
            <div class="mb-4">
                <label class="block text-xs text-muted-foreground mb-2">Template</label>
                <div class="grid grid-cols-2 gap-2 max-h-48 overflow-y-auto pr-1">
                    @foreach (var t in templates)
                    {
                        var selected = selectedTemplate == t.Slug;
                        var btnClass = selected
                            ? "text-left px-3 py-2.5 rounded-md border border-primary bg-primary/5 text-foreground"
                            : "text-left px-3 py-2.5 rounded-md border border-border text-muted-foreground hover:border-border/80 hover:text-foreground transition-colors";
                        <button class="@btnClass" @onclick="() => SelectTemplate(t.Slug)">
                            <div class="flex items-center gap-2 mb-0.5">
                                <SvgIcon Name="bot" Class="w-3.5 h-3.5 flex-shrink-0" />
                                <span class="text-xs font-medium truncate">@t.Name</span>
                            </div>
                            <p class="text-xs text-muted-foreground/70 font-mono truncate">@t.Role</p>
                        </button>
                    }
                </div>
                @if (selectedTemplateObj != null)
                {
                    <p class="text-xs text-muted-foreground mt-2">@selectedTemplateObj.Description</p>
                }
            </div>
        }

        <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Display name</label>
                    <input value="@name"
                           @oninput="OnNameInput"
                           placeholder="Dev Sam"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Slug</label>
                    <input value="@agentSlug"
                           @oninput="e => agentSlug = e.Value?.ToString() ?? string.Empty"
                           placeholder="dev-sam"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(error))
            {
                <p class="text-xs text-destructive">@error</p>
            }
        </div>

        <div class="flex justify-end gap-3 mt-5">
            <button @onclick="OnClose"
                    class="text-xs px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground transition-colors">
                Cancel
            </button>
            <button @onclick="Create"
                    disabled="@saving"
                    class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 disabled:opacity-50 transition-colors">
                <SvgIcon Name="plus" Class="w-3 h-3" />
                @(saving ? "Creating…" : "Add agent")
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string ProjectSlug { get; set; } = string.Empty;
    [Parameter, EditorRequired] public EventCallback OnCreated { get; set; }
    [Parameter, EditorRequired] public EventCallback OnClose { get; set; }

    private List<AgentTemplate> templates = [];
    private AgentSlug? selectedTemplate;
    private AgentTemplate? selectedTemplateObj;
    private string name = string.Empty;
    private string agentSlug = string.Empty;
    private bool saving;
    private string error = string.Empty;

    protected override void OnInitialized()
    {
        templates = TemplatesService.ListTemplates();
        var preferred = templates.FirstOrDefault(t => t.Slug == "generic-standard") ?? templates.FirstOrDefault();
        if (preferred != null) SelectTemplate(preferred.Slug);
    }

    private void SelectTemplate(AgentSlug slug)
    {
        selectedTemplate = slug;
        selectedTemplateObj = templates.FirstOrDefault(t => t.Slug == slug);
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        name = e.Value?.ToString() ?? string.Empty;
        agentSlug = new string(name.ToLowerInvariant()
            .Replace(' ', '-')
            .Where(c => char.IsLetterOrDigit(c) || c == '-')
            .ToArray())
            .Trim('-');
    }

    private async Task Create()
    {
        error = string.Empty;
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(agentSlug))
        {
            error = "Name and slug are required.";
            return;
        }
        if (selectedTemplate == null)
        {
            error = "A template is required.";
            return;
        }
        saving = true;
        try
        {
            var err = AgentService.CreateAgent(ProjectSlug, agentSlug.Trim(), name.Trim(), selectedTemplate);
            if (err != null) { error = err; return; }
            await OnCreated.InvokeAsync();
            await OnClose.InvokeAsync();
        }
        finally
        {
            saving = false;
        }
    }
}
