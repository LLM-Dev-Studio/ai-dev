@{
    var cls = Model switch
    {
        "opus"   => "bg-purple-500/15 text-purple-400 border-purple-500/20",
        "haiku"  => "bg-amber-500/15 text-amber-400 border-amber-500/20",
        _        => "bg-blue-500/15 text-blue-400 border-blue-500/20",
    };
}

<span class="inline-flex items-center text-xs font-medium px-2 py-0.5 rounded-full border @cls">@(Model ?? "sonnet")</span>

@code {
    [Parameter] public string? Model { get; set; }
}
