<div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-card border border-border rounded-lg w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-5">
            <p class="text-sm font-semibold text-foreground">New Template</p>
            <button @onclick="OnClose" class="p-1 text-muted-foreground hover:text-foreground transition-colors">
                <SvgIcon Name="x" Class="w-4 h-4" />
            </button>
        </div>

        <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Name</label>
                    <input value="@name"
                           @oninput="OnNameInput"
                           placeholder="My Developer"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Slug</label>
                    <input value="@slug"
                           @oninput="e => slug = e.Value?.ToString() ?? string.Empty"
                           placeholder="my-developer"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Role</label>
                    <select value="@role"
                            @onchange="e => role = e.Value?.ToString() ?? string.Empty"
                            class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                        @foreach (var r in Roles)
                        {
                            <option value="@r" selected="@(role == r)">@r</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Model</label>
                    @if (ModelAliases.Count > 0)
                    {
                        <select value="@model"
                                @onchange="e => model = e.Value?.ToString() ?? string.Empty"
                                class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                            @foreach (var alias in ModelAliases)
                            {
                                <option value="@alias" selected="@(model == alias)">@alias</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input value="@model"
                               @oninput="e => model = e.Value?.ToString() ?? string.Empty"
                               class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                    }
                </div>
            </div>
            <div>
                <label class="block text-xs text-muted-foreground mb-1">Description</label>
                <input value="@description"
                       @oninput="e => description = e.Value?.ToString() ?? string.Empty"
                       class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>
            @if (!string.IsNullOrEmpty(error))
            {
                <p class="text-xs text-destructive">@error</p>
            }
        </div>

        <div class="flex justify-end gap-3 mt-5">
            <button @onclick="OnClose"
                    class="text-xs px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground transition-colors">
                Cancel
            </button>
            <button @onclick="Create"
                    disabled="@saving"
                    class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 disabled:opacity-50 transition-colors">
                <SvgIcon Name="plus" Class="w-3 h-3" />
                @(saving ? "Creating…" : "Create")
            </button>
        </div>
    </div>
</div>

@code {
    private static readonly List<string> Roles =
    [
        "analyst", "architect", "designer", "developer", "devops",
        "growth-marketing", "guard", "process-evo", "project-manager", "qa", "generic"
    ];

    [Parameter, EditorRequired] public List<string> ModelAliases { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<AgentTemplate> OnCreated { get; set; }
    [Parameter, EditorRequired] public EventCallback OnClose { get; set; }

    private string name = string.Empty;
    private string slug = string.Empty;
    private string role = "developer";
    private string model = string.Empty;
    private string description = string.Empty;
    private bool saving;
    private string error = string.Empty;

    protected override void OnInitialized()
    {
        model = ModelAliases.Count > 0 ? ModelAliases[0] : "sonnet";
    }

    private void OnNameInput(ChangeEventArgs e)
    {
        name = e.Value?.ToString() ?? string.Empty;
        slug = new string(name.ToLowerInvariant()
            .Replace(' ', '-')
            .Where(c => char.IsLetterOrDigit(c) || c == '-')
            .ToArray());
    }

    private async Task Create()
    {
        error = string.Empty;
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(slug))
        {
            error = "Name and slug are required";
            return;
        }

        saving = true;
        try
        {
            var template = new AgentTemplate
            {
                Slug = slug,
                Name = name,
                Role = role,
                Model = model,
                Description = description,
                Content = string.Empty,
            };
            await OnCreated.InvokeAsync(template);
            await OnClose.InvokeAsync();
        }
        catch
        {
            error = "Failed to create template";
        }
        finally
        {
            saving = false;
        }
    }
}
