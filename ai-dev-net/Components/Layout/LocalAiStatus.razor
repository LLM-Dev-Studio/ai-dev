@using AiDev.Executors
@using AiDev.Services
@implements IDisposable
@inject ExecutorHealthMonitor ExecutorHealthMonitor

@foreach (var (executor, health) in ExecutorHealthMonitor.GetExecutorHealth())
{
    <div class="px-3 py-2 flex items-center gap-2 text-xs text-muted-foreground"
         title="@Tooltip(health)">
        <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 @DotClass(health)"></span>
        <span>@executor.DisplayName</span>
        <span class="ml-auto @LabelClass(health)">@Label(health)</span>
    </div>
}

@if (!ExecutorHealthMonitor.GetExecutorHealth().Any())
{
    <div class="px-3 py-2 text-xs text-muted-foreground">No executors registered</div>
}

@code {
    protected override void OnInitialized()
    {
        ExecutorHealthMonitor.Changed += OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private static string DotClass(ExecutorHealthResult health) => health.IsHealthy
        ? "bg-emerald-400"
        : "bg-red-400";

    private static string Label(ExecutorHealthResult health) => health.IsHealthy
        ? "Online"
        : "Offline";

    private static string LabelClass(ExecutorHealthResult health) => health.IsHealthy
        ? "text-emerald-400"
        : "text-red-400";

    private string Tooltip(ExecutorHealthResult health)
    {
        var checkedAt = ExecutorHealthMonitor.LastChecked is { } t
            ? $" · checked {t.ToLocalTime():HH:mm:ss}"
            : string.Empty;
        return $"{health.Message}{checkedAt}";
    }

    public void Dispose()
    {
        ExecutorHealthMonitor.Changed -= OnChanged;
    }
}
