@page "/projects/{Slug}/decisions/{DecisionId}"
@using AiDev.Features.Decision
@using AiDev.Features.Agent
@using AiDev.Models
@using AiDev.Models.Types
@using AiDev.Services
@using System.Diagnostics
@rendermode InteractiveServer
@inject DecisionsService DecisionsService
@inject DecisionChatService ChatService
@inject AgentRunnerService RunnerService
@inject AgentService AgentService
@inject DecisionChangedNotifier DecisionNotifier
@inject NavigationManager NavigationManager
@inject ILogger<DecisionDetailPage> Logger
@implements IDisposable

<a href="@($"/projects/{Slug}/decisions")"
   class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground mb-4 transition-colors">
    <SvgIcon Name="arrow-left" Class="w-3 h-3" />
    Back to decisions
</a>

@if (decision == null)
{
    <div class="max-w-2xl">
        <div class="h-8 w-64 bg-muted rounded animate-pulse mb-4"></div>
        <div class="h-48 rounded-lg border border-border bg-card animate-pulse"></div>
    </div>
}
else
{
    <div class="max-w-2xl">
        <!-- Header -->
        <div class="flex items-start gap-3 mb-6">
            <div class="flex-1">
                <h1 class="text-xl font-semibold text-foreground">@decision.Subject</h1>
                <div class="flex items-center gap-3 mt-1 flex-wrap">
                    <span class="text-xs text-muted-foreground">
                        from <span class="text-foreground/70">@decision.From</span>
                    </span>
                    <span class="text-xs text-muted-foreground">@FormatDateTime(decision.Date)</span>
                    <span class="text-xs px-1.5 py-0.5 rounded border @StatusBadge(decision.Status.Value)">@decision.Status.Value</span>
                </div>
            </div>
        </div>

        <!-- Original decision body -->
        <div class="rounded-lg border border-border bg-card p-5 mb-4">
            <p class="text-xs text-muted-foreground mb-2">Decision request</p>
            <pre class="whitespace-pre-wrap text-sm text-foreground/90 font-sans leading-relaxed">@decision.Body</pre>
        </div>

        <!-- Chat history -->
        @if (chatMessages.Count > 0 || decision.Status.IsPending)
        {
            <div class="space-y-3 mb-4">
                @foreach (var msg in chatMessages)
                {
                    <div class="@(msg.IsHuman ? "flex justify-end" : "flex justify-start")">
                        <div class="max-w-[80%] rounded-lg px-4 py-3 @(msg.IsHuman ? "bg-primary text-primary-foreground" : "border border-border bg-card text-foreground")">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="text-xs opacity-70">@(msg.IsHuman ? "You" : msg.From)</span>
                                <span class="text-xs opacity-50">@FormatDateTime(msg.Timestamp)</span>
                            </div>
                            <pre class="whitespace-pre-wrap text-sm font-sans leading-relaxed">@msg.Content</pre>
                        </div>
                    </div>
                }

                @if (messageQueued)
                {
                    <div class="flex justify-start">
                        <div class="rounded-lg px-4 py-3 border border-border bg-card text-muted-foreground">
                            <div class="flex items-center gap-2 text-xs">
                                <div class="w-1.5 h-1.5 rounded-full bg-sky-400"></div>
                                @decision.From reply queued…
                            </div>
                        </div>
                    </div>
                }
                else if (agentIsRunning)
                {
                    <div class="flex justify-start">
                        <div class="rounded-lg px-4 py-3 border border-border bg-card text-muted-foreground">
                            <div class="flex items-center gap-2 text-xs">
                                <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></div>
                                @decision.From is thinking…
                            </div>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(agentFailure))
                {
                    <div class="flex justify-start">
                        <div class="rounded-lg px-4 py-3 border border-amber-500/30 bg-amber-500/10 text-amber-100/90 max-w-[80%]">
                            <div class="flex items-center gap-2 text-xs text-amber-200 mb-1">
                                <SvgIcon Name="alert-triangle" Class="w-3.5 h-3.5" />
                                @decision.From stopped before replying
                            </div>
                            <p class="text-xs">@agentFailure</p>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Resolved response display -->
        @if (!string.IsNullOrEmpty(decision.Response))
        {
            <div class="rounded-lg border border-emerald-400/20 bg-emerald-400/5 p-5 mb-4">
                <div class="flex items-center gap-2 mb-2">
                    <SvgIcon Name="check-circle-2" Class="w-4 h-4 text-emerald-400" />
                    <p class="text-sm font-medium text-emerald-400">Resolved</p>
                    <span class="text-xs text-muted-foreground">@FormatDateTime(decision.ResolvedAt)</span>
                </div>
                <pre class="whitespace-pre-wrap text-sm text-foreground/90 font-sans leading-relaxed">@decision.Response</pre>
            </div>
        }

        <!-- Chat input and resolve for pending decisions -->
        @if (decision.Status.IsPending)
        {
            @if (!showResolveDialog)
            {
                <div class="rounded-lg border border-border bg-card p-4">
                    <textarea value="@chatInput"
                              @oninput="e => chatInput = e.Value?.ToString() ?? string.Empty"
                              @onkeydown="OnChatKeyDown"
                              placeholder="Type your message… (Shift+Enter for new line, Enter to send)"
                              rows="3"
                              class="w-full bg-background border border-border rounded-md p-3 text-sm text-foreground placeholder:text-muted-foreground resize-none focus:outline-none focus:ring-1 focus:ring-primary mb-3"></textarea>
                    @if (!string.IsNullOrEmpty(chatError))
                    {
                        <p class="text-xs text-destructive mb-2">@chatError</p>
                    }
                    <div class="flex items-center justify-between">
                        <button @onclick="StartResolve"
                                class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md border border-emerald-500/40 bg-emerald-500/10 text-emerald-400 hover:bg-emerald-500/20 transition-colors">
                            <SvgIcon Name="check-circle-2" Class="w-3 h-3" />
                            Resolve
                        </button>
                        <button @onclick="SendMessage"
                                disabled="@(sendingMessage || string.IsNullOrWhiteSpace(chatInput))"
                                class="flex items-center gap-1.5 px-4 py-2 rounded-md bg-primary text-primary-foreground text-sm font-medium disabled:opacity-50 hover:bg-primary/90 transition-colors">
                            <SvgIcon Name="send" Class="w-3.5 h-3.5" />
                            @(sendingMessage ? "Sending…" : "Send")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="rounded-lg border border-emerald-400/30 bg-card p-5">
                    <p class="text-sm font-medium text-foreground mb-1">Resolve this decision</p>
                    <p class="text-xs text-muted-foreground mb-3">Optionally provide a summary that will be sent to the agent.</p>
                    <textarea value="@resolveResponse"
                              @oninput="e => resolveResponse = e.Value?.ToString() ?? string.Empty"
                              placeholder="Resolution summary (optional)…"
                              rows="3"
                              class="w-full bg-background border border-border rounded-md p-3 text-sm text-foreground placeholder:text-muted-foreground resize-none focus:outline-none focus:ring-1 focus:ring-primary mb-3"></textarea>
                    @if (!string.IsNullOrEmpty(resolveError))
                    {
                        <p class="text-xs text-destructive mb-2">@resolveError</p>
                    }
                    <div class="flex justify-end gap-3">
                        <button @onclick="() => { showResolveDialog = false; resolveError = string.Empty; }"
                                class="px-3 py-1.5 rounded-md border border-border text-sm text-muted-foreground hover:text-foreground transition-colors">
                            Cancel
                        </button>
                        <button @onclick="Resolve"
                                disabled="@submitting"
                                class="flex items-center gap-1.5 px-4 py-2 rounded-md bg-emerald-600 text-white text-sm font-medium disabled:opacity-50 hover:bg-emerald-500 transition-colors">
                            <SvgIcon Name="check-circle-2" Class="w-3.5 h-3.5" />
                            @(submitting ? "Resolving…" : "Confirm Resolution")
                        </button>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [Parameter] public string DecisionId { get; set; } = string.Empty;

    private DecisionItem? decision;
    private IReadOnlyList<DecisionChatMessage> chatMessages = [];
    private string chatInput = string.Empty;
    private bool sendingMessage;
    private string chatError = string.Empty;
    private AgentInfo? agentInfo;
    private bool agentIsRunning;
    private bool messageQueued;
    private string? agentFailure;
    private Timer? _pollTimer;
    private bool _disposed;

    private bool showResolveDialog;
    private string resolveResponse = string.Empty;
    private bool submitting;
    private string resolveError = string.Empty;

    protected override void OnInitialized()
    {
        decision = DecisionsService.GetDecision(Slug, DecisionId);
        if (decision == null) return;

        DecisionNotifier.Changed += OnDecisionChanged;
        RefreshDecisionState(flushReplies: true);

        if (decision.Status.IsPending)
        {
            _pollTimer = new Timer(_ => _ = InvokeAsync(PollAsync), null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
        }
    }

    private void OnDecisionChanged(ProjectSlug project)
    {
        if (project.Value != Slug) return;
        InvokeAsync(() =>
        {
            RefreshDecisionState(flushReplies: false);
            StateHasChanged();
        });
    }

    private Task PollAsync()
    {
        if (_disposed || decision == null)
            return Task.CompletedTask;

        try
        {
            RefreshDecisionState(flushReplies: true);
            StateHasChanged();
        }
        catch (IOException ex)
        {
            Logger.LogDebug(ex, "Decision detail refresh hit transient I/O for {ProjectSlug}/{DecisionId}", Slug, DecisionId);
        }
        catch (InvalidOperationException ex) when (_disposed)
        {
            Logger.LogDebug(ex, "Decision detail refresh stopped after disposal for {ProjectSlug}/{DecisionId}", Slug, DecisionId);
        }

        return Task.CompletedTask;
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(chatInput) || decision == null) return;
        sendingMessage = true;
        chatError = string.Empty;
        var content = chatInput;
        chatInput = string.Empty;

        try
        {
            var err = ChatService.SendHumanMessage(Slug, DecisionId, decision.From, content);
            if (err != null)
            {
                chatError = err;
                chatInput = content;
                return;
            }

            RefreshDecisionState(flushReplies: false);
            // Ensure queued indicator appears immediately even if agent picks up inbox before the poll
            if (!messageQueued && !agentIsRunning)
                messageQueued = decision?.Status.IsPending == true;
        }
        catch (IOException ex)
        {
            Logger.LogWarning(ex, "Decision send failed with transient I/O for {ProjectSlug}/{DecisionId}", Slug, DecisionId);
            chatError = "Failed to send the reply due to a temporary file error.";
            chatInput = content;
        }
        catch (UnauthorizedAccessException ex)
        {
            Logger.LogWarning(ex, "Decision send failed with access error for {ProjectSlug}/{DecisionId}", Slug, DecisionId);
            chatError = "Failed to send the reply because the workspace files could not be updated.";
            chatInput = content;
        }
        catch (InvalidOperationException ex) when (_disposed)
        {
            Logger.LogDebug(ex, "Decision send stopped after disposal for {ProjectSlug}/{DecisionId}", Slug, DecisionId);
        }
        finally
        {
            sendingMessage = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void StartResolve()
    {
        resolveResponse = chatInput.Trim();
        chatInput = string.Empty;
        showResolveDialog = true;
    }

    private async Task OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task Resolve()
    {
        if (decision == null) return;
        submitting = true;
        resolveError = string.Empty;
        // Flush any last agent replies before closing the decision.
        ChatService.FlushAgentReplies(Slug, DecisionId, decision.From);
        var response = string.IsNullOrWhiteSpace(resolveResponse) ? "Resolved." : resolveResponse.Trim();
        using var activity = AiDevTelemetry.ActivitySource.StartActivity("UI.Decision.Resolve", ActivityKind.Internal);
        activity?.SetTag("ui.page", "decision-detail");
        activity?.SetTag("project.slug", Slug);
        activity?.SetTag("decision.id", DecisionId);
        var err = (await DecisionsService.ResolveDecisionAsync(Slug, DecisionId, response))
            .ToErrorMessage();
        activity?.SetTag("ui.outcome", string.IsNullOrEmpty(err) ? "success" : "error");
        submitting = false;
        if (err != null) { resolveError = err; return; }
        NavigationManager.NavigateTo($"/projects/{Slug}/decisions");
    }

    public void Dispose()
    {
        _disposed = true;
        _pollTimer?.Dispose();
        DecisionNotifier.Changed -= OnDecisionChanged;
    }

    private static string StatusBadge(string status) => DecisionStatus.From(status).IsResolved
        ? "border-emerald-400/20 text-emerald-400"
        : "border-orange-400/20 text-orange-400";

    private static string FormatDateTime(DateTime? dt) =>
        dt.HasValue ? dt.Value.ToLocalTime().ToString("MMM d HH:mm") : string.Empty;

    private void RefreshDecisionState(bool flushReplies)
    {
        if (decision == null)
            return;

        if (flushReplies)
            ChatService.FlushAgentReplies(Slug, DecisionId, decision.From);

        decision = DecisionsService.GetDecision(Slug, DecisionId);
        if (decision == null)
        {
            chatMessages = [];
            agentInfo = null;
            agentIsRunning = false;
            messageQueued = false;
            agentFailure = null;
            return;
        }

        chatMessages = ChatService.GetMessages(Slug, DecisionId);
        agentInfo = AgentService.LoadAgent(Slug, decision.From);

        var waitingForReply = decision.Status.IsPending && chatMessages.LastOrDefault() is { IsHuman: true };
        var isRunning = RunnerService.IsRunning(Slug, decision.From);
        var inboxCount = agentInfo?.InboxCount ?? 0;

        messageQueued = waitingForReply && inboxCount > 0;
        agentIsRunning = waitingForReply && isRunning && !messageQueued;
        agentFailure = waitingForReply && agentInfo?.Status.IsError == true
            ? agentInfo.LastError
            : null;
    }
}
