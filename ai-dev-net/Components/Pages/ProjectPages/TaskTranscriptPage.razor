@page "/projects/{Slug}/board/tasks/{TaskId}/transcript"
@rendermode InteractiveServer
@inject BoardService BoardService
@inject MessagesService MessagesService
@using AiDev.Features.Board
@using AiDev.Models
@using AiDev.Models.Types
@using AiDev.Services
@using Markdig

<a href="@($"/projects/{Slug}/board")"
   class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground mb-4 transition-colors">
    <SvgIcon Name="arrow-left" Class="w-3 h-3" />
    Back to Board
</a>

<div class="mb-4">
    <h1 class="text-xl font-semibold text-primary">Task Transcript</h1>
    @if (_task != null)
    {
        <p class="text-sm text-muted-foreground mt-0.5">@_task.Title</p>
    }
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="mb-4 rounded-lg border border-destructive/30 bg-destructive/10 px-3 py-2">
        <p class="text-sm text-destructive">@_error</p>
    </div>
}
else if (_task == null)
{
    <EmptyState Icon="file-text" Title="Task not found" Description="This task does not exist on the board." />
}
else if (_messages.Count == 0)
{
    <EmptyState Icon="file-text" Title="No transcript yet" Description="No task-linked messages were found for this task." />
}
else
{
    <div class="space-y-2">
        @foreach (var message in _messages)
        {
            <div class="rounded-lg border border-border bg-card p-4">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-sm font-medium text-foreground truncate">@message.Re</p>
                        <p class="text-xs text-muted-foreground mt-0.5">
                            <span class="text-foreground/70">@message.From</span>
                            <span class="mx-1">→</span>
                            <span class="text-foreground/70">@message.To</span>
                            @if (!string.IsNullOrWhiteSpace(message.Type))
                            {
                                <span class="ml-2 px-1.5 py-0.5 rounded border @TypeColor(message.Type)">@message.Type</span>
                            }
                        </p>
                    </div>
                    <span class="text-xs text-muted-foreground flex-shrink-0">@FormatDateTime(message.Date)</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(message.Body))
                {
                    <div class="markdown-body mt-3">@((MarkupString)RenderMarkdown(message.Body))</div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [Parameter] public string TaskId { get; set; } = string.Empty;

    private BoardTask? _task;
    private List<MessageItem> _messages = [];
    private string _error = string.Empty;

    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    protected override void OnParametersSet()
    {
        _error = string.Empty;
        _messages = [];
        _task = null;

        if (!AiDev.Models.Types.TaskId.TryParse(TaskId, out var parsedTaskId))
        {
            _error = "Invalid task id.";
            return;
        }

        var board = BoardService.LoadBoard(Slug);
        if (!board.Tasks.TryGetValue(parsedTaskId, out var task))
        {
            return;
        }

        _task = task;
        _messages = MessagesService.ListMessages(Slug)
            .Where(message => message.TaskId == parsedTaskId)
            .OrderByDescending(message => message.Date)
            .ThenByDescending(message => message.Filename)
            .ToList();
    }

    private static string RenderMarkdown(string markdown) =>
        Markdig.Markdown.ToHtml(markdown, Pipeline);

    private static string FormatDateTime(DateTime? dt) =>
        dt.HasValue ? dt.Value.ToLocalTime().ToString("MMM d HH:mm:ss") : "Unknown";

    private static string TypeColor(string? type) => type switch
    {
        "task"             => "bg-blue-500/10 text-blue-400 border-blue-500/30",
        "bug-report"       => "bg-red-500/10 text-red-400 border-red-500/30",
        "question"         => "bg-yellow-500/10 text-yellow-400 border-yellow-500/30",
        "approval"         => "bg-green-500/10 text-green-400 border-green-500/30",
        "update"           => "bg-purple-500/10 text-purple-400 border-purple-500/30",
        "decision-request" => "bg-orange-500/10 text-orange-400 border-orange-500/30",
        _                  => "border-border text-muted-foreground",
    };
}
