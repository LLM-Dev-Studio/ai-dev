@page "/projects/{Slug}/codebase"
@rendermode InteractiveServer
@inject WorkspaceService WorkspaceService
@inject GitService GitService

<h1 class="text-xl font-semibold text-foreground mb-4">Codebase</h1>

@if (!codebaseInitialized && !initDone)
{
    <div class="mb-6 rounded-lg border border-yellow-500/20 bg-yellow-500/10 p-4">
        <div class="flex items-center gap-2 mb-4">
            <SvgIcon Name="alert-triangle" Class="w-4 h-4 text-yellow-500 flex-shrink-0" />
            <p class="text-sm font-semibold text-foreground">Codebase not initialized</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
            <button type="button" @onclick="SetModeCreate"
                    class="text-left rounded-md border-2 bg-card/60 p-3.5 transition-colors @(initMode == "create" ? "border-blue-500" : "border-white/10 hover:border-white/20")">
                <div class="flex items-center gap-2 mb-1.5">
                    <SvgIcon Name="folder-git-2" Class="@CreateIconClass" />
                    <span class="text-sm font-medium @(initMode == "create" ? "text-foreground" : "text-muted-foreground")">Create new codebase</span>
                </div>
                <p class="text-xs text-muted-foreground leading-relaxed">
                    Initialize a new git repo at <code class="font-mono text-muted-foreground/80">workspaces/@Slug/codebase/</code>
                </p>
            </button>

            <button type="button" @onclick="SetModeLink"
                    class="text-left rounded-md border-2 bg-card/60 p-3.5 transition-colors @(initMode == "link" ? "border-blue-500" : "border-white/10 hover:border-white/20")">
                <div class="flex items-center gap-2 mb-1.5">
                    <SvgIcon Name="folder-open" Class="@LinkIconClass" />
                    <span class="text-sm font-medium @(initMode == "link" ? "text-foreground" : "text-muted-foreground")">Link existing codebase</span>
                </div>
                <p class="text-xs text-muted-foreground leading-relaxed">
                    Point to an existing repo already on your filesystem
                </p>
            </button>
        </div>

        @if (initMode == "link")
        {
            <div class="mb-4">
                <label class="block text-xs font-medium text-muted-foreground mb-1.5">Absolute path to codebase</label>
                <input value="@customPath"
                       @oninput="e => customPath = e.Value?.ToString() ?? string.Empty"
                       placeholder="C:\dev\my-project"
                       spellcheck="false"
                       autocomplete="off"
                       class="w-full rounded-md border border-border bg-card/80 px-3 py-2 font-mono text-sm text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-colors" />
            </div>
        }

        <div class="flex items-center gap-3">
            <button @onclick="Initialize"
                    disabled="@(!CanSubmit)"
                    class="inline-flex items-center gap-2 rounded-md px-3.5 py-1.5 border border-border bg-card text-sm font-medium text-foreground hover:bg-accent disabled:opacity-40 disabled:cursor-not-allowed transition-colors focus:outline-none focus:ring-1 focus:ring-ring">
                @if (isInitializing)
                {
                    <span class="w-3.5 h-3.5 rounded-full border-2 border-muted-foreground/30 border-t-muted-foreground animate-spin flex-shrink-0"></span>
                    <span>Initializing…</span>
                }
                else
                {
                    <SvgIcon Name="folder-git-2" Class="w-3.5 h-3.5 flex-shrink-0" />
                    <span>Initialize</span>
                }
            </button>
            @if (!string.IsNullOrEmpty(initError))
            {
                <p class="text-xs text-destructive">@initError</p>
            }
        </div>
    </div>
}

@if (initDone)
{
    <div class="rounded-lg border border-emerald-500/20 bg-emerald-500/10 p-4 mb-6">
        <div class="flex items-center gap-2">
            <SvgIcon Name="check-circle-2" Class="w-4 h-4 text-emerald-400" />
            <p class="text-sm font-medium text-emerald-400">Codebase initialized successfully.</p>
        </div>
    </div>
}

<div class="rounded-lg border border-border bg-card p-5 mb-6">
    <p class="text-sm font-semibold text-foreground mb-4">Project Info</p>
    <div class="space-y-2 text-sm">
        <div class="flex items-center justify-between">
            <span class="text-muted-foreground">Project slug</span>
            <span class="font-mono text-foreground/80">@Slug</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-muted-foreground">Workspace path</span>
            <span class="font-mono text-xs text-foreground/80 truncate ml-4">@projectDir</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-muted-foreground">Codebase status</span>
            <span class="text-foreground/80">@(codebaseInitialized ? "Initialized" : "Not initialized")</span>
        </div>
        @if (!string.IsNullOrEmpty(codebasePath))
        {
            <div class="flex items-center justify-between">
                <span class="text-muted-foreground">Codebase path</span>
                <span class="font-mono text-xs text-foreground/80 truncate ml-4">@codebasePath</span>
            </div>
        }
        @if (codebaseInitialized && !string.IsNullOrEmpty(codebasePath))
        {
            <div class="flex items-center justify-between">
                <span class="text-muted-foreground">Git repository</span>
                <span class="text-foreground/80">@(isGitRepo ? "Yes" : "No")</span>
            </div>
        }
    </div>
</div>

@if (codebaseInitialized && isGitRepo)
{
    <div class="flex gap-6">
        <!-- Commits list -->
        <div class="@(selectedCommit != null ? "w-80 flex-shrink-0" : "flex-1")">
            <div class="flex items-center justify-between mb-3">
                <p class="text-sm font-semibold text-foreground">Commits</p>
                @if (commits != null)
                {
                    <span class="text-xs text-muted-foreground">@commits.Count shown</span>
                }
            </div>

            @if (commits == null)
            {
                <div class="space-y-2">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="h-14 rounded-lg border border-border bg-card animate-pulse"></div>
                    }
                </div>
            }
            else if (commits.Count == 0)
            {
                <EmptyState Icon="git-commit-horizontal" Title="No commits yet" Description="Commits will appear here once the repository has history." />
            }
            else
            {
                <div class="space-y-1">
                    @foreach (var c in commits)
                    {
                        <button @onclick="() => SelectCommit(c.Hash)"
                                class="w-full text-left rounded-lg border p-3 transition-colors @(selectedCommit?.Commit.Hash == c.Hash ? "border-blue-500 bg-blue-500/10" : "border-border bg-card hover:border-border/60 hover:bg-accent/50")">
                            <div class="flex items-start justify-between gap-2">
                                <p class="text-sm text-foreground line-clamp-1 flex-1 min-w-0">@c.Subject</p>
                                <code class="text-xs font-mono text-muted-foreground flex-shrink-0">@c.ShortHash</code>
                            </div>
                            <p class="text-xs text-muted-foreground mt-0.5">@c.Author · @FormatDate(c.Date)</p>
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Commit detail -->
        @if (selectedCommit != null)
        {
            <div class="flex-1 min-w-0">
                <div class="rounded-lg border border-border bg-card overflow-hidden">
                    <div class="flex items-center justify-between px-4 py-3 border-b border-border">
                        <div class="flex items-center gap-2 min-w-0">
                            <SvgIcon Name="git-commit-horizontal" Class="w-4 h-4 text-muted-foreground flex-shrink-0" />
                            <p class="text-sm font-medium text-foreground truncate">@selectedCommit.Commit.Subject</p>
                        </div>
                        <button @onclick="CloseDetail" class="ml-3 flex-shrink-0 text-muted-foreground hover:text-foreground transition-colors">
                            <SvgIcon Name="x" Class="w-4 h-4" />
                        </button>
                    </div>

                    <div class="px-4 py-3 border-b border-border space-y-1 text-xs text-muted-foreground">
                        <div class="flex items-center gap-2">
                            <span class="w-16 flex-shrink-0">Hash</span>
                            <code class="font-mono text-foreground/80">@selectedCommit.Commit.Hash</code>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-16 flex-shrink-0">Author</span>
                            <span class="text-foreground/80">@selectedCommit.Commit.Author &lt;@selectedCommit.Commit.AuthorEmail&gt;</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-16 flex-shrink-0">Date</span>
                            <span class="text-foreground/80">@FormatDateFull(selectedCommit.Commit.Date)</span>
                        </div>
                        @if (!string.IsNullOrEmpty(selectedCommit.Body))
                        {
                            <div class="flex items-start gap-2 pt-1">
                                <span class="w-16 flex-shrink-0">Body</span>
                                <p class="text-foreground/80 whitespace-pre-wrap">@selectedCommit.Body</p>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(selectedCommit.Diff))
                    {
                        <div class="overflow-auto max-h-[60vh]">
                            <pre class="p-4 text-xs font-mono leading-relaxed text-foreground/80 whitespace-pre">@selectedCommit.Diff</pre>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private string projectDir = string.Empty;
    private bool codebaseInitialized;
    private string codebasePath = string.Empty;
    private string initMode = "create";
    private string customPath = string.Empty;
    private bool isInitializing;
    private string initError = string.Empty;
    private bool initDone;
    private bool isGitRepo;

    private List<GitCommit>? commits;
    private GitCommitDetail? selectedCommit;

    private bool CanSubmit => !isInitializing && (initMode == "create" || !string.IsNullOrWhiteSpace(customPath));
    private string CreateIconClass => initMode == "create" ? "w-4 h-4 flex-shrink-0 text-blue-400" : "w-4 h-4 flex-shrink-0 text-muted-foreground";
    private string LinkIconClass => initMode == "link" ? "w-4 h-4 flex-shrink-0 text-blue-400" : "w-4 h-4 flex-shrink-0 text-muted-foreground";

    private void SetModeCreate() => initMode = "create";
    private void SetModeLink() => initMode = "link";

    protected override void OnInitialized()
    {
        projectDir = WorkspaceService.GetProjectPath(Slug);
        var projectJsonPath = Path.Combine(projectDir, "project.json");
        if (File.Exists(projectJsonPath))
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(File.ReadAllText(projectJsonPath));
                var root = doc.RootElement;
                if (root.TryGetProperty("codebaseInitialized", out var ci))
                    codebaseInitialized = ci.GetBoolean();
                if (root.TryGetProperty("codebasePath", out var cp))
                    codebasePath = cp.GetString() ?? string.Empty;
            }
            catch { }
        }

        if (codebaseInitialized && !string.IsNullOrEmpty(codebasePath))
        {
            isGitRepo = GitService.IsGitRepo(codebasePath);
            if (isGitRepo)
                commits = GitService.GetLog(codebasePath);
        }
    }

    private void Initialize()
    {
        isInitializing = true;
        initError = string.Empty;
        try
        {
            if (initMode == "create")
            {
                var cbDir = Path.Combine(projectDir, "codebase");
                Directory.CreateDirectory(cbDir);
                UpdateProjectJson(cbDir, true);
                codebasePath = cbDir;
            }
            else
            {
                var path = customPath.Trim();
                if (!Directory.Exists(path)) throw new Exception($"Directory not found: {path}");
                UpdateProjectJson(path, true);
                codebasePath = path;
            }
            codebaseInitialized = true;
            initDone = true;
            isGitRepo = GitService.IsGitRepo(codebasePath);
            if (isGitRepo)
                commits = GitService.GetLog(codebasePath);
        }
        catch (Exception ex)
        {
            initError = ex.Message;
        }
        finally
        {
            isInitializing = false;
        }
    }

    private void SelectCommit(string hash)
    {
        selectedCommit = GitService.GetCommit(codebasePath, hash);
    }

    private void CloseDetail()
    {
        selectedCommit = null;
    }

    private void UpdateProjectJson(string cbPath, bool initialized)
    {
        var path = Path.Combine(projectDir, "project.json");
        var json = File.Exists(path) ? File.ReadAllText(path) : "{}";
        var doc = System.Text.Json.JsonDocument.Parse(json);
        var dict = new Dictionary<string, object?>();
        foreach (var prop in doc.RootElement.EnumerateObject())
            dict[prop.Name] = prop.Value;
        dict["codebaseInitialized"] = initialized;
        dict["codebasePath"] = cbPath;
        File.WriteAllText(path, System.Text.Json.JsonSerializer.Serialize(dict,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true }));
    }

    private static string FormatDate(string? iso)
    {
        if (string.IsNullOrEmpty(iso)) return string.Empty;
        if (DateTimeOffset.TryParse(iso, out var dt)) return dt.ToLocalTime().ToString("MMM d");
        return iso;
    }

    private static string FormatDateFull(string? iso)
    {
        if (string.IsNullOrEmpty(iso)) return string.Empty;
        if (DateTimeOffset.TryParse(iso, out var dt)) return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz");
        return iso;
    }
}
