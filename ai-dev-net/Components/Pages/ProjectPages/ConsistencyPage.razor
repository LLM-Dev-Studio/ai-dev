@page "/projects/{Slug}/consistency"
@rendermode InteractiveServer
@using AiDev.Models
@using AiDev.Services
@inject ConsistencyCheckService ConsistencyCheckService

<h1 class="text-xl font-semibold text-primary mb-1">Consistency</h1>
<p class="text-sm text-muted-foreground mb-4">Review startup findings and run an on-demand consistency scan for this project.</p>

@if (_loading)
{
    <div class="space-y-3 mt-5">
        <div class="h-8 rounded-md bg-muted animate-pulse"></div>
        <div class="h-24 rounded-md bg-muted animate-pulse"></div>
        <div class="h-24 rounded-md bg-muted animate-pulse"></div>
    </div>
}
else if (_report == null)
{
    <EmptyState Icon="shield-alert" Title="No consistency data" Description="Run a scan to inspect board and decision state for this project." />
}
else
{
    <div class="flex items-center justify-between mb-4">
        <div class="text-sm text-muted-foreground">
            <span class="mr-3">Warnings: @_report.Findings.Count(f => f.Severity == ConsistencySeverity.Warning)</span>
            <span>Errors: @_report.Findings.Count(f => f.Severity == ConsistencySeverity.Error)</span>
        </div>
        <button @onclick="RunScanAsync"
                disabled="@_loading"
                class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 disabled:opacity-50 transition-colors">
            <SvgIcon Name="refresh-cw" Class="w-3 h-3" />
            @(_loading ? "Scanning…" : "Run scan")
        </button>
    </div>

    @if (_report.Findings.Count == 0)
    {
        <div class="rounded-md border border-border bg-card px-4 py-3 text-sm text-foreground">
            No issues found for this project.
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var finding in _report.Findings)
            {
                <div class="rounded-md border border-border bg-card px-4 py-3">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <p class="text-sm font-medium text-foreground">@finding.Code</p>
                            <p class="text-xs text-muted-foreground mt-1">@finding.Message</p>
                        </div>
                        <div class="text-right text-[11px] uppercase tracking-wide text-muted-foreground">
                            <p>@finding.Severity</p>
                            <p>@finding.FixType</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(finding.ResourceId))
                    {
                        <p class="text-[11px] text-muted-foreground/80 mt-2 font-mono">Resource: @finding.ResourceId</p>
                    }
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private ProjectConsistencyReport? _report;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await RunScanAsync();
    }

    private async Task RunScanAsync()
    {
        _loading = true;
        StateHasChanged();
        _report = await ConsistencyCheckService.CheckProjectAsync(Slug);
        _loading = false;
    }
}
