@page "/projects/{Slug}/agents/{AgentSlug}"
@rendermode InteractiveServer
@inject AgentService AgentService
@inject MessagesService MessagesService
@inject AgentRunnerService RunnerService
@inject NavigationManager NavigationManager
@inject ExecutorHealthMonitor ExecutorHealthMonitor
@inject IModelRegistry ModelRegistry
@using AiDev.Executors
@using AiDev.Features.Agent
@using AiDev.Models
@using AiDev.Models.Types
@using AiDev.Services
@implements IDisposable

<a href="@($"/projects/{Slug}")"
   class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground mb-4 transition-colors">
    <SvgIcon Name="arrow-left" Class="w-3 h-3" />
    Back to agents
</a>

@if (agent == null)
{
    <LoadingGrid Count="3" />
}
else
{
    <div class="flex items-start gap-3 mb-6">
        <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
                <h1 class="text-xl font-semibold text-primary">@agent.Name</h1>
                <StatusBadge Status="@(isRunning ? AgentStatus.Running : agent.Status)" />
                <ModelBadge Model="@agent.Model" />
            </div>
            <p class="text-sm text-muted-foreground">@agent.Description</p>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
            <a href="@($"/projects/{Slug}/agents/{AgentSlug}/transcript")"
               class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground hover:bg-accent/50 transition-colors">
                <SvgIcon Name="scroll-text" Class="w-3 h-3" />
                Transcript
            </a>
            @if (isRunning)
            {
                <button @onclick="StopAgent"
                        class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md border border-red-500/40 bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-colors">
                    <SvgIcon Name="square" Class="w-3 h-3" />
                    Stop
                </button>
            }
            else
            {
                <button @onclick="LaunchAgent"
                        class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md border border-emerald-500/40 bg-emerald-500/10 text-emerald-400 hover:bg-emerald-500/20 transition-colors">
                    <SvgIcon Name="play" Class="w-3 h-3" />
                    Run
                </button>
            }
        </div>
    </div>

    @if (!isRunning && agent.LastError is { Length: > 0 })
    {
        <div class="mb-6 rounded-lg border border-amber-500/30 bg-amber-500/10 p-4">
            <div class="flex items-start gap-3">
                <SvgIcon Name="alert-triangle" Class="w-4 h-4 text-amber-400 mt-0.5 flex-shrink-0" />
                <div class="min-w-0">
                    <p class="text-sm font-medium text-amber-200">Last run needs attention</p>
                    <p class="text-sm text-amber-100/90 mt-1">@agent.LastError</p>
                    <div class="flex items-center gap-3 mt-2 text-xs text-amber-200/80">
                        <span>@FormatDateTime(agent.LastErrorAt)</span>
                        <a href="@($"/projects/{Slug}/agents/{AgentSlug}/transcript")"
                           class="underline underline-offset-2 hover:text-amber-100 transition-colors">
                            Open transcript
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="grid grid-cols-3 gap-4 mb-8">
        <div class="rounded-lg border border-border bg-card p-4">
            <p class="text-xs text-muted-foreground mb-1">Role</p>
            <p class="text-sm font-medium text-foreground font-mono">@(string.IsNullOrEmpty(agent.Role) ? "—" : agent.Role)</p>
        </div>
        <div class="rounded-lg border border-border bg-card p-4">
            <p class="text-xs text-muted-foreground mb-1">Last run</p>
            <p class="text-sm font-medium text-foreground">@FormatDate(agent.LastRunAt)</p>
        </div>
        <div class="rounded-lg border border-border bg-card p-4">
            <p class="text-xs text-muted-foreground mb-1">Inbox</p>
            <p class="text-sm font-medium text-foreground">@agent.InboxCount message@(agent.InboxCount != 1 ? "s" : "")</p>
        </div>
    </div>
    @if (lastSessionUsage != null)
    {
        <div class="rounded-lg border border-border bg-card p-4 mb-6">
            <p class="text-xs text-muted-foreground mb-2">Last session tokens</p>
            <div class="flex items-center gap-6 flex-wrap">
                <div>
                    <span class="text-xs text-muted-foreground">In </span>
                    <span class="text-sm font-mono font-medium text-foreground">@lastSessionUsage.InputTokens.ToString("N0")</span>
                </div>
                <div>
                    <span class="text-xs text-muted-foreground">Out </span>
                    <span class="text-sm font-mono font-medium text-foreground">@lastSessionUsage.OutputTokens.ToString("N0")</span>
                </div>
                @{
                    var usageModel = ModelRegistry.GetModelsForExecutor(agent.Executor.Value)
                        .FirstOrDefault(m => m.Id == agent.Model);
                    var cost = usageModel != null ? lastSessionUsage.EstimatedCost(usageModel) : null;
                }
                @if (cost.HasValue)
                {
                    <div>
                        <span class="text-xs text-muted-foreground">Cost </span>
                        <span class="text-sm font-mono font-medium text-foreground">$@cost.Value.ToString("F4")</span>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Configuration -->
    <div class="space-y-3 mb-8">
        <div class="rounded-lg border border-border bg-card p-5">
            <p class="text-sm font-semibold text-foreground mb-4">Agent Configuration</p>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs text-muted-foreground mb-1">Name</label>
                    <input value="@editName"
                           @oninput="e => editName = e.Value?.ToString() ?? string.Empty"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs text-muted-foreground mb-1">Executor</label>
                        <select value="@editExecutor.Value"
                                @onchange="OnExecutorChanged"
                                class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                            @foreach (var option in executorOptions)
                            {
                                <option value="@option.Name.Value" selected="@(option.Name == editExecutor)">
                                        @(option.Health.IsHealthy ? option.DisplayName : option.DisplayName + " (offline)")
                                    </option>
                            }
                        </select>
                        @if (SelectedExecutorOption is { } selectedExecutor && !selectedExecutor.Health.IsHealthy)
                        {
                            <div class="mt-2 rounded-md border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-xs text-amber-100/90">
                                This executor is offline. The agent may not start until it comes back online.
                            </div>
                        }
                    </div>
                    <div>
                        <label class="block text-xs text-muted-foreground mb-1">Model</label>
                        @{
                            var executorModels = ModelRegistry.GetModelsForExecutor(editExecutor.Value);
                        }
                        @if (executorModels.Count > 0)
                        {
                            <select value="@editModel"
                                    @onchange="OnModelChanged"
                                    class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                                @foreach (var m in executorModels)
                                {
                                    <option value="@m.Id" selected="@(m.Id == editModel)">
                                        @m.DisplayName@(m.Capabilities.HasFlag(ModelCapabilities.ToolCalling) ? " 🔧" : "")@(m.Capabilities.HasFlag(ModelCapabilities.Vision) ? " 👁" : "")@(m.Capabilities.HasFlag(ModelCapabilities.Reasoning) ? " 🧠" : "")
                                    </option>
                                }
                            </select>
                        }
                        else
                        {
                            <input value="@editModel"
                                   @oninput="e => editModel = e.Value?.ToString() ?? string.Empty"
                                   placeholder="e.g. gpt-4o"
                                   class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                        }

                        @if (ShowOllamaToolWarning)
                        {
                            <div class="mt-2 rounded-md border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-xs text-amber-100/90">
                                @OllamaToolWarningMessage
                            </div>
                        }
                    </div>
                </div>
                <div class="col-span-2">
                    <label class="block text-xs text-muted-foreground mb-1">Description</label>
                    <input value="@editDescription"
                           @oninput="e => editDescription = e.Value?.ToString() ?? string.Empty"
                           class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
                </div>
                @{
                    var availableSkills = SelectedExecutorOption == null
                        ? (IReadOnlyList<ExecutorSkill>)[]
                        : ExecutorHealthMonitor.GetExecutorHealth()
                            .Where(e => e.Executor.Name == SelectedExecutorOption.Name.Value)
                            .SelectMany(e => e.Executor.AvailableSkills)
                            .ToList();
                }
                @if (availableSkills.Count > 0)
                {
                    <div class="col-span-2">
                        <label class="block text-xs text-muted-foreground mb-1">Skills</label>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var skill in availableSkills)
                            {
                                var isChecked = editSkills.Contains(skill.Key);
                                <label class="flex items-center gap-1.5 text-sm cursor-pointer" title="@skill.Description">
                                    <input type="checkbox" checked="@isChecked"
                                           @onchange="@(e => { if ((bool?)e.Value == true) editSkills.Add(skill.Key); else editSkills.Remove(skill.Key); })"
                                           class="accent-primary" />
                                    @skill.DisplayName
                                </label>
                            }
                        </div>
                    </div>
                }
                @{
                    var selectedModelDescriptor = ModelRegistry.GetModelsForExecutor(editExecutor.Value)
                        .FirstOrDefault(m => m.Id == editModel);
                    var modelSupportsThinking = selectedModelDescriptor?.Capabilities.HasFlag(ModelCapabilities.Reasoning) == true;
                }
                @if (modelSupportsThinking)
                {
                    <div class="col-span-2">
                        <label class="block text-xs text-muted-foreground mb-1">Thinking level 🧠</label>
                        <select value="@editThinkingLevel.ToString()"
                                @onchange="e => editThinkingLevel = ThinkingLevelExtensions.Parse(e.Value?.ToString())"
                                class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring">
                            @foreach (var level in Enum.GetValues<ThinkingLevel>())
                            {
                                <option value="@level.Serialize()" selected="@(editThinkingLevel == level)">@level.ToDisplayName()</option>
                            }
                        </select>
                        <p class="mt-1 text-xs text-muted-foreground">Extended thinking budget in tokens (@editThinkingLevel.BudgetTokens())</p>
                    </div>
                }
            </div>
            <div class="flex items-center justify-end gap-3 mt-4">
                @if (metaStatus == SaveStatus.Saved)
                {
                    <span class="text-xs text-green-500">Saved</span>
                }
                @if (metaStatus == SaveStatus.Error)
                {
                    <span class="text-xs text-destructive">Error saving</span>
                }
                <button @onclick="SaveMeta"
                        disabled="@(!IsMetaDirty || savingMeta)"
                        class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 disabled:opacity-50 transition-colors">
                    <SvgIcon Name="save" Class="w-3 h-3" />
                    @(savingMeta ? "Saving…" : "Save")
                </button>
            </div>
        </div>

        <!-- CLAUDE.md collapsible -->
        <div class="rounded-lg border border-border bg-card">
            <button @onclick="() => claudeExpanded = !claudeExpanded"
                    class="w-full flex items-center justify-between px-5 py-4 text-left">
                <div>
                    <p class="text-sm font-semibold text-foreground">Instructions (CLAUDE.md)</p>
                    <p class="text-xs text-muted-foreground mt-0.5">Passed to the agent on every session — keep this focused and lean</p>
                </div>
                <SvgIcon Name="@(claudeExpanded ? "chevron-up" : "chevron-down")" Class="w-4 h-4 text-muted-foreground flex-shrink-0" />
            </button>
            @if (claudeExpanded)
            {
                <div class="px-5 pb-5 border-t border-border">
                    <textarea value="@claudeContent"
                              @oninput="e => claudeContent = e.Value?.ToString() ?? string.Empty"
                              class="w-full mt-4 rounded-md border border-border bg-background px-3 py-2 text-xs font-mono text-foreground/90 leading-relaxed resize-y focus:outline-none focus:ring-1 focus:ring-ring min-h-48"
                              spellcheck="false" rows="12"></textarea>
                    <div class="flex items-center justify-between mt-3">
                        <button @onclick="ResetClaude"
                                class="flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors">
                            <SvgIcon Name="rotate-ccw" Class="w-3 h-3" />
                            Reload from disk
                        </button>
                        <div class="flex items-center gap-3">
                            @if (claudeStatus == SaveStatus.Saved)
                            {
                                <span class="text-xs text-green-500">Saved</span>
                            }
                            @if (claudeStatus == SaveStatus.Error)
                            {
                                <span class="text-xs text-destructive">Error saving</span>
                            }
                            <button @onclick="SaveClaude"
                                    disabled="@(!IsClaudeDirty || savingClaude)"
                                    class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 disabled:opacity-50 transition-colors">
                                <SvgIcon Name="save" Class="w-3 h-3" />
                                @(savingClaude ? "Saving…" : "Save")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Inbox -->
    <h2 class="text-sm font-semibold text-foreground mb-3">Inbox</h2>
    @if (messages.Count == 0)
    {
        <EmptyState Icon="inbox" Title="Inbox is empty" />
    }
    else
    {
        <div class="space-y-3">
            @foreach (var msg in messages)
            {
                <div class="rounded-lg border border-border bg-card p-4">
                    <div class="flex items-start justify-between mb-2">
                        <div>
                            <p class="text-sm font-medium text-foreground">@msg.Re</p>
                            <p class="text-xs text-muted-foreground mt-0.5">
                                from <span class="text-foreground/70">@msg.From</span>
                            </p>
                        </div>
                        <div class="flex items-center gap-2 ml-3 flex-shrink-0">
                            <span class="text-xs px-1.5 py-0.5 rounded border border-border text-muted-foreground">@msg.Type</span>
                            <span class="text-xs text-muted-foreground">@FormatDateTime(msg.Date)</span>
                        </div>
                    </div>
                    <p class="text-sm text-muted-foreground line-clamp-3">@msg.Body</p>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [Parameter] public string AgentSlug { get; set; } = string.Empty;

    private AgentInfo? agent;
    private List<MessageItem> messages = [];
    private List<ExecutorOption> executorOptions = [];
    private bool isRunning;
    private Timer? _pollTimer;

    // Editable meta
    private string editName = string.Empty;
    private string editDescription = string.Empty;
    private string editModel = string.Empty;
    private AgentExecutorName editExecutor = AgentExecutorName.Default;
    private ThinkingLevel editThinkingLevel = ThinkingLevel.Off;
    private string originalName = string.Empty;
    private string originalDescription = string.Empty;
    private string originalModel = string.Empty;
    private AgentExecutorName originalExecutor = AgentExecutorName.Default;
    private ThinkingLevel originalThinkingLevel = ThinkingLevel.Off;
    private HashSet<string> editSkills = [];
    private HashSet<string> originalSkills = [];
    private bool savingMeta;
    private SaveStatus metaStatus;
    private TokenUsage? lastSessionUsage;

    // CLAUDE.md
    private string claudeContent = string.Empty;
    private string claudeOriginal = string.Empty;
    private bool claudeExpanded;
    private bool savingClaude;
    private SaveStatus claudeStatus;

    private enum SaveStatus { Idle, Saved, Error }

    private sealed record ExecutorOption(AgentExecutorName Name, string DisplayName, ExecutorHealthResult Health);

    private bool IsMetaDirty => editName != originalName || editDescription != originalDescription
        || editModel != originalModel || editExecutor != originalExecutor
        || editThinkingLevel != originalThinkingLevel
        || !editSkills.SetEquals(originalSkills);
    private bool IsClaudeDirty => claudeContent != claudeOriginal;
    private ExecutorOption? SelectedExecutorOption => executorOptions.FirstOrDefault(option => option.Name == editExecutor);

    protected override void OnInitialized()
    {
        agent = AgentService.LoadAgent(Slug, AgentSlug);
        if (agent == null) return;

        editName = originalName = agent.Name;
        editDescription = originalDescription = agent.Description;
        editModel = originalModel = agent.Model;
        editExecutor = originalExecutor = agent.Executor;
        editThinkingLevel = originalThinkingLevel = agent.ThinkingLevel;
        editSkills = [.. agent.Skills];
        originalSkills = [.. agent.Skills];
        lastSessionUsage = RunnerService.GetLastSessionUsage(Slug, AgentSlug);

        claudeContent = claudeOriginal = AgentService.GetClaudeMd(Slug, AgentSlug);
        executorOptions = ExecutorHealthMonitor.GetExecutorHealth()
            .Select(entry => new ExecutorOption(
                AgentExecutorName.TryParse(entry.Executor.Name, out var executorName) ? executorName : AgentExecutorName.Default,
                entry.Executor.DisplayName,
                entry.Health))
            .DistinctBy(option => option.Name)
            .OrderBy(option => option.DisplayName)
            .ToList();
        messages = MessagesService.ListMessages(Slug, AgentSlug);
        isRunning = RunnerService.IsRunning(Slug, AgentSlug);

        // Poll every 2 s to reflect live run state
        _pollTimer = new Timer(_ =>
        {
            var running = RunnerService.IsRunning(Slug, AgentSlug);
            if (running != isRunning)
            {
                InvokeAsync(() =>
                {
                    isRunning = running;
                    ReloadAgentState();
                    StateHasChanged();
                });
            }
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));

        ExecutorHealthMonitor.Changed += OnHealthChanged;
    }

    private void OnHealthChanged()
    {
        InvokeAsync(() =>
        {
            executorOptions = ExecutorHealthMonitor.GetExecutorHealth()
                .Select(entry => new ExecutorOption(
                    AgentExecutorName.TryParse(entry.Executor.Name, out var executorName) ? executorName : AgentExecutorName.Default,
                    entry.Executor.DisplayName,
                    entry.Health))
                .DistinctBy(option => option.Name)
                .OrderBy(option => option.DisplayName)
                .ToList();
            StateHasChanged();
        });
    }

    private void OnExecutorChanged(ChangeEventArgs args)
    {
        if (!AgentExecutorName.TryParse(args.Value?.ToString(), out var executor))
            return;

        SetExecutor(executor);
    }

    private void SetExecutor(AgentExecutorName executor)
    {
        editExecutor = executor;
        // Only reset the model if the current value is not valid for the new executor.
        var executorModels = ModelRegistry.GetModelsForExecutor(executor.Value);
        if (executorModels.Count > 0)
        {
            if (!executorModels.Any(m => m.Id == editModel))
                editModel = executorModels[0].Id;
        }
        // else: free-text model — preserve whatever is set
        ResetThinkingIfNotSupported();
    }

    private void OnModelChanged(ChangeEventArgs args)
    {
        editModel = args.Value?.ToString() ?? string.Empty;
        ResetThinkingIfNotSupported();
    }

    private void ResetThinkingIfNotSupported()
    {
        var supportsReasoning = ModelRegistry.GetModelsForExecutor(editExecutor.Value)
            .FirstOrDefault(m => m.Id == editModel)
            ?.Capabilities.HasFlag(ModelCapabilities.Reasoning) == true;
        if (!supportsReasoning)
            editThinkingLevel = ThinkingLevel.Off;
    }

    private void LaunchAgent()
    {
        RunnerService.LaunchAgent(Slug, AgentSlug);
        isRunning = true;
    }

    private void StopAgent()
    {
        RunnerService.StopAgent(Slug, AgentSlug);
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
        ExecutorHealthMonitor.Changed -= OnHealthChanged;
    }

    private bool ShowOllamaToolWarning =>
        editExecutor == AgentExecutorName.Ollama
        && WorkspaceToolsEnabled
        && global::AiDev.Executors.OllamaToolSupport.IsKnownUnsupportedModel(editModel);

    private bool WorkspaceToolsEnabled =>
        agent != null && global::AiDev.Executors.OllamaToolSupport.AreWorkspaceToolsEnabled(agent.Skills);

    private string? OllamaToolWarningMessage =>
        ShowOllamaToolWarning ? global::AiDev.Executors.OllamaToolSupport.GetUnsupportedToolsMessage(editModel) : null;

    private void ReloadAgentState()
    {
        agent = AgentService.LoadAgent(Slug, AgentSlug);
        messages = MessagesService.ListMessages(Slug, AgentSlug);
    }

    private void SaveMeta()
    {
        savingMeta = true;
        metaStatus = SaveStatus.Idle;
        var err = AgentService.SaveAgentMeta(Slug, AgentSlug, editName, editDescription, editModel, editExecutor, [.. editSkills], editThinkingLevel)
            .ToErrorMessage();
        savingMeta = false;
        if (err != null) { metaStatus = SaveStatus.Error; return; }
        originalName = editName;
        originalDescription = editDescription;
        originalModel = editModel;
        originalExecutor = editExecutor;
        originalThinkingLevel = editThinkingLevel;
        originalSkills = [.. editSkills];
        ReloadAgentState();
        metaStatus = SaveStatus.Saved;
        Task.Delay(2000).ContinueWith(_ => { metaStatus = SaveStatus.Idle; InvokeAsync(StateHasChanged); });
    }

    private void SaveClaude()
    {
        savingClaude = true;
        claudeStatus = SaveStatus.Idle;
        var err = AgentService.SaveClaudeMd(Slug, AgentSlug, claudeContent)
            .ToErrorMessage();
        savingClaude = false;
        if (err != null) { claudeStatus = SaveStatus.Error; return; }
        claudeOriginal = claudeContent;
        claudeStatus = SaveStatus.Saved;
        Task.Delay(2000).ContinueWith(_ => { claudeStatus = SaveStatus.Idle; InvokeAsync(StateHasChanged); });
    }

    private void ResetClaude()
    {
        claudeContent = AgentService.GetClaudeMd(Slug, AgentSlug);
        claudeOriginal = claudeContent;
        claudeStatus = SaveStatus.Idle;
    }

    private static string FormatDate(DateTime? dt) =>
        dt.HasValue ? dt.Value.ToLocalTime().ToString("MMM d") : "—";

    private static string FormatDateTime(DateTime? dt) =>
        dt.HasValue ? dt.Value.ToLocalTime().ToString("MMM d HH:mm") : string.Empty;
}
