@page "/projects/{Slug}/secrets"
@using AiDev.Features.Secrets
@rendermode InteractiveServer
@inject SecretsService SecretsService
@inject NavigationManager NavigationManager

<a href="@($"/projects/{Slug}")"
   class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground mb-4 transition-colors">
    <SvgIcon Name="arrow-left" Class="w-3 h-3" />
    Back to agents
</a>

<div class="max-w-xl space-y-6">

    <div>
        <h2 class="text-base font-semibold text-primary mb-1">Project Secrets</h2>
        <p class="text-xs text-muted-foreground">
            Secrets are encrypted at rest and injected as environment variables into each agent session.
            Values are never displayed after saving.
        </p>
    </div>

    <!-- Secret list -->
    @if (secretNames.Count == 0)
    {
        <p class="text-sm text-muted-foreground">No secrets configured.</p>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var name in secretNames)
            {
                <div class="flex items-center justify-between p-3 rounded-md border border-border bg-card">
                    <div class="flex items-center gap-2 min-w-0">
                        <SvgIcon Name="lock" Class="w-3.5 h-3.5 text-muted-foreground flex-shrink-0" />
                        <span class="text-sm font-mono text-foreground truncate">@name</span>
                    </div>
                    <div class="flex items-center gap-2 ml-3 flex-shrink-0">
                        <span class="text-xs text-muted-foreground font-mono">••••••••</span>
                        <button @onclick="() => ConfirmDelete(name)"
                                class="text-xs text-destructive hover:text-destructive/80 transition-colors px-2 py-1 rounded hover:bg-destructive/10">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Delete confirmation -->
    @if (deletingSecret != null)
    {
        <div class="p-4 rounded-md border border-destructive/40 bg-destructive/5 space-y-3">
            <p class="text-sm text-foreground">
                Delete secret <span class="font-mono font-medium">@deletingSecret</span>? This cannot be undone.
            </p>
            <div class="flex gap-2">
                <button @onclick="ExecuteDelete"
                        class="text-xs px-3 py-1.5 rounded-md bg-destructive text-destructive-foreground hover:bg-destructive/90 transition-colors">
                    Delete
                </button>
                <button @onclick="() => deletingSecret = null"
                        class="text-xs px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    }

    <!-- Add secret form -->
    @if (!showAddForm)
    {
        <button @onclick="() => showAddForm = true"
                class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground transition-colors">
            <SvgIcon Name="plus" Class="w-3 h-3" />
            Add secret
        </button>
    }
    else
    {
        <div class="p-4 rounded-md border border-border bg-card space-y-3">
            <p class="text-xs font-medium text-foreground">New secret</p>

            <div>
                <label class="block text-xs text-muted-foreground mb-1">Name</label>
                <input @bind="newName"
                       placeholder="MY_API_KEY"
                       class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
                <p class="text-xs text-muted-foreground/60 mt-1">Use uppercase letters and underscores, e.g. OPENAI_API_KEY.</p>
            </div>

            <div>
                <label class="block text-xs text-muted-foreground mb-1">Value</label>
                <input type="password"
                       @bind="newValue"
                       placeholder="sk-…"
                       class="w-full rounded-md border border-border bg-background px-3 py-1.5 text-sm text-foreground font-mono focus:outline-none focus:ring-1 focus:ring-ring" />
            </div>

            @if (!string.IsNullOrEmpty(addError))
            {
                <p class="text-xs text-destructive">@addError</p>
            }
            @if (addSuccess)
            {
                <p class="text-xs text-green-600">Secret saved.</p>
            }

            <div class="flex gap-2 justify-end">
                <button @onclick="CancelAdd"
                        class="text-xs px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground transition-colors">
                    Cancel
                </button>
                <button @onclick="SaveSecret"
                        class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
                    <SvgIcon Name="save" Class="w-3 h-3" />
                    Save secret
                </button>
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private List<string> secretNames = [];
    private bool showAddForm;
    private string newName = string.Empty;
    private string newValue = string.Empty;
    private string addError = string.Empty;
    private bool addSuccess;
    private string? deletingSecret;

    protected override void OnInitialized() => Reload();

    private void Reload()
    {
        secretNames = [.. SecretsService.ListSecrets(Slug)];
    }

    private void SaveSecret()
    {
        addError = string.Empty;
        addSuccess = false;

        if (string.IsNullOrWhiteSpace(newName))
        {
            addError = "Name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newValue))
        {
            addError = "Value is required.";
            return;
        }

        try
        {
            SecretsService.SetSecret(Slug, newName.Trim(), newValue);
            addSuccess = true;
            newName = string.Empty;
            newValue = string.Empty;
            Reload();
        }
        catch (Exception ex)
        {
            addError = $"Failed to save secret: {ex.Message}";
        }
    }

    private void CancelAdd()
    {
        showAddForm = false;
        newName = string.Empty;
        newValue = string.Empty;
        addError = string.Empty;
        addSuccess = false;
    }

    private void ConfirmDelete(string name) => deletingSecret = name;

    private void ExecuteDelete()
    {
        if (deletingSecret == null) return;
        SecretsService.DeleteSecret(Slug, deletingSecret);
        deletingSecret = null;
        Reload();
    }
}
