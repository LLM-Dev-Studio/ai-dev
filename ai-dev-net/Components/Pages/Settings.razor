@page "/settings"
@using AiDev.Models
@using AiDev.Services
@rendermode InteractiveServer
@inject StudioSettingsService SettingsService

<PageTitle>Settings</PageTitle>

<PageHeader Title="Studio Settings" Description="Global configuration for AI Dev Studio." />

<div class="rounded-lg border border-border bg-card p-6 mt-6">
    <div class="rounded-md border border-border bg-muted/40 p-4 mb-6">
        <p class="text-sm font-medium text-foreground">Configuration source</p>
        <p class="text-xs text-muted-foreground mt-1">
            Studio settings are loaded from ASP.NET Core configuration sources such as <code class="text-xs font-mono">appsettings.json</code>,
            user secrets, and environment variables. Update configuration outside the app and restart after changes.
        </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 mb-6">
        <div>
            <label class="block text-xs text-muted-foreground mb-1">Ollama base URL</label>
            <input value="@settings.OllamaBaseUrl"
                   disabled
                   class="w-full rounded-md border border-border bg-muted px-3 py-1.5 text-sm text-muted-foreground font-mono cursor-not-allowed" />
        </div>
        <div>
            <label class="block text-xs text-muted-foreground mb-1">Anthropic API key</label>
            <input value="@(string.IsNullOrWhiteSpace(settings.AnthropicApiKey) ? "Not configured" : "Configured")"
                   disabled
                   class="w-full rounded-md border border-border bg-muted px-3 py-1.5 text-sm text-muted-foreground font-mono cursor-not-allowed" />
        </div>
    </div>

    <div class="flex items-center justify-between mb-1">
        <div>
            <p class="text-sm font-semibold text-foreground">Model Aliases</p>
            <p class="text-xs text-muted-foreground mt-0.5">
                Map short names used in <code class="text-xs font-mono">agent.json</code> to full Claude model IDs passed to the CLI.
            </p>
        </div>
    </div>

    <div class="mt-4 space-y-2">
        <div class="grid gap-2 px-1" style="grid-template-columns: 1fr 2fr;">
            <p class="text-xs text-muted-foreground font-medium">Alias</p>
            <p class="text-xs text-muted-foreground font-medium">Model ID</p>
        </div>

        @if (rows.Count == 0)
        {
            <p class="text-sm text-muted-foreground">No model aliases are configured.</p>
        }
        else
        {
            @foreach (var row in rows)
            {
                <div class="grid gap-2 items-center" style="grid-template-columns: 1fr 2fr;">
                    <input value="@row.Alias"
                           disabled
                           class="rounded-md border border-border bg-muted px-3 py-1.5 text-xs text-muted-foreground font-mono cursor-not-allowed" />
                    <input value="@row.ModelId"
                           disabled
                           class="rounded-md border border-border bg-muted px-3 py-1.5 text-xs text-muted-foreground font-mono cursor-not-allowed" />
                </div>
            }
        }
    </div>
</div>

<div class="rounded-lg border border-border bg-card p-6 mt-4">
    <p class="text-sm font-semibold text-foreground mb-1">Executors</p>
    <p class="text-xs text-muted-foreground mb-4">Live health status for all registered AI executors.</p>
    <ExecutorStatusPanel />
</div>

@code {
    private record AliasRow(string Alias, string ModelId);

    private StudioSettings settings = new();
    private List<AliasRow> rows = [];

    protected override void OnInitialized()
    {
        settings = SettingsService.GetSettings();
        rows = settings.Models.Select(kv => new AliasRow(kv.Key, kv.Value)).ToList();
    }
}
