<wpfui:FluentWindow x:Class="AiDev.Desktop.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:pages="clr-namespace:AiDev.Desktop.Views.Pages"
                 mc:Ignorable="d"
                 Title="AI Dev Net"
                 MinWidth="1100"
                 MinHeight="700"
                 Width="1280"
                 Height="800"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <wpfui:TitleBar Grid.Row="0"
                     Title="AI Dev Net" />

        <!-- Main navigation layout -->
        <wpfui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsPaneOpen="True"
                           OpenPaneLength="220"
                           IsBackButtonVisible="Collapsed"
                           
                           FrameMargin="0">

            <wpfui:NavigationView.MenuItems>
                <wpfui:NavigationViewItem Content="Projects"
                                       TargetPageType="{x:Type pages:ProjectsPage}"
                                       Icon="{wpfui:SymbolIcon FolderOpen24}" />
            </wpfui:NavigationView.MenuItems>

            <wpfui:NavigationView.FooterMenuItems>
                <wpfui:NavigationViewItem Content="Settings"
                                       TargetPageType="{x:Type pages:SettingsPage}"
                                       Icon="{wpfui:SymbolIcon Settings24}" />
            </wpfui:NavigationView.FooterMenuItems>

            <!-- Custom pane header -->
            <wpfui:NavigationView.PaneHeader>
                <StackPanel Margin="8,4,8,0">
                    <TextBlock Text="AI Dev Net"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="4,0,0,8" />
                    <Separator Margin="0,0,0,4" />
                </StackPanel>
            </wpfui:NavigationView.PaneHeader>

            <!-- Pane footer: executor health -->
            <wpfui:NavigationView.PaneFooter>
                <Border Margin="8,4" Padding="8,6"
                        CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Executor Health"
                                   FontSize="11"
                                   Opacity="0.6"
                                   Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding ExecutorStatuses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding HealthColor}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </wpfui:NavigationView.PaneFooter>

        </wpfui:NavigationView>

        <!-- Snackbar for notifications -->
        <wpfui:SnackbarPresenter x:Name="SnackbarPresenter"
                              Grid.Row="1"
                              VerticalAlignment="Bottom" />

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>
    </Grid>
</wpfui:FluentWindow>
