<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- Card hover effect -->
    <Style x:Key="ClickableCard" TargetType="wpfui:Card">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.9" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Subtle section label -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <!-- TextTransform not available in WPF; use Typography.Capitals if needed -->
    </Style>

    <!-- Badge-style border for counts -->
    <Style x:Key="CountBadge" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

</ResourceDictionary>
