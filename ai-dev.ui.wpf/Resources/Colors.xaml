<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Priority colours -->
    <SolidColorBrush x:Key="PriorityCriticalBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="PriorityHighBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="PriorityNormalBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="PriorityLowBrush" Color="#6B7280" />

    <!-- Agent status colours -->
    <SolidColorBrush x:Key="AgentRunningBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="AgentIdleBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="AgentErrorBrush" Color="#EF4444" />
</ResourceDictionary>
