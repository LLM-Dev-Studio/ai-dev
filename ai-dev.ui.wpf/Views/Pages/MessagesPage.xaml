<Page x:Class="AiDev.Desktop.Views.Pages.MessagesPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:conv="clr-namespace:AiDev.Desktop.Converters"
         Title="Messages">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:PriorityColorConverter x:Key="PriorityColor" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Messages" FontSize="28" FontWeight="SemiBold" />
            <CheckBox Content="Show processed"
                      IsChecked="{Binding ShowProcessed}"
                      Margin="20,0,0,0"
                      VerticalAlignment="Center"
                      Command="{Binding LoadCommand}" />
        </StackPanel>

        <!-- Message list -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="0,0,16,0">
            <Grid>
                <wpfui:ProgressRing IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ListBox ItemsSource="{Binding Messages}"
                         SelectedItem="{Binding SelectedMessage}"
                         Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                                        <Border Width="3"
                                                CornerRadius="2"
                                                Background="{Binding Priority, Converter={StaticResource PriorityColor}}"
                                                Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Re}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="From:" />
                                        <Run Text="{Binding From, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Date, StringFormat='{}{0:MMM d, HH:mm}'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Message detail -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="16,0,0,0">
            <StackPanel Visibility="{Binding SelectedMessage, Converter={StaticResource BoolToVisible}}">
                <TextBlock Text="{Binding SelectedMessage.Re}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="From:" FontWeight="Medium" />
                        <Run Text="{Binding SelectedMessage.From, Mode=OneWay}" />
                        <Run Text="  To:" FontWeight="Medium" />
                        <Run Text="{Binding SelectedMessage.To, Mode=OneWay}" />
                        <Run Text="  " />
                        <Run Text="{Binding SelectedMessage.Date, Mode=OneWay, StringFormat='{}{0:MMM d, yyyy HH:mm}'}" />
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="{Binding SelectedMessage.Body}"
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="22"
                           Margin="0,0,0,20" />
                <wpfui:Button Content="Mark as Processed"
                           Appearance="Primary"
                           Icon="{wpfui:SymbolIcon Checkmark24}"
                           Command="{Binding MarkProcessedCommand}"
                           CommandParameter="{Binding SelectedMessage}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
