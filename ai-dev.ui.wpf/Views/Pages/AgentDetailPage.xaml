<Page x:Class="AiDev.Desktop.Views.Pages.AgentDetailPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:conv="clr-namespace:AiDev.Desktop.Converters"
         Title="Agent Detail">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:AgentStatusColorConverter x:Key="StatusColor" />
        <conv:AgentStatusTextConverter x:Key="StatusText" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="24" MaxWidth="700">
            <!-- Loading -->
            <wpfui:ProgressRing IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                             HorizontalAlignment="Center" />

            <StackPanel Visibility="{Binding Agent, Converter={StaticResource NullToVisible}}">
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Ellipse Width="12" Height="12"
                             Fill="{Binding Agent.Status, Converter={StaticResource StatusColor}}"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0" />
                    <TextBlock Text="{Binding Agent.Name}"
                               FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding Agent.Role}"
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="22,0,0,24" />

                <!-- Status card -->
                <wpfui:Card Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Status" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Agent.Status, Converter={StaticResource StatusText}}"
                                       FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Inbox" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Agent.InboxCount}"
                                       FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Last Run" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Agent.LastRunAt, StringFormat='{}{0:MMM d}'}"
                                       FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </wpfui:Card>

                <!-- Model + executor card -->
                <wpfui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Configuration" FontSize="14" FontWeight="Medium" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Model" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <wpfui:Badge Grid.Column="1" Content="{Binding Agent.Model}" Appearance="Info" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Executor" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <wpfui:Badge Grid.Column="1" Content="{Binding Agent.Executor.Value}" Appearance="Secondary" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Thinking" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Agent.ThinkingLevel}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </wpfui:Card>

                <!-- Error card -->
                <wpfui:Card Margin="0,0,0,16"
                         Background="#1F1500"
                         Visibility="{Binding Agent.LastError, Converter={StaticResource NullToVisible}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <wpfui:SymbolIcon Symbol="ErrorCircle24" Foreground="#EF4444" Margin="0,0,8,0" />
                            <TextBlock Text="Last run failed" FontWeight="Medium" Foreground="#EF4444" />
                        </StackPanel>
                        <TextBlock Text="{Binding Agent.LastError}"
                                   TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </wpfui:Card>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal">
                    <wpfui:Button Content="Run Agent"
                               Appearance="Primary"
                               Icon="{wpfui:SymbolIcon Play24}"
                               Command="{Binding RunAsyncCommand}"
                               Margin="0,0,8,0" />
                    <wpfui:Button Content="Stop"
                               Icon="{wpfui:SymbolIcon Stop24}"
                               Command="{Binding StopAsyncCommand}"
                               Margin="0,0,8,0" />
                    <wpfui:Button Content="View Transcript"
                               Icon="{wpfui:SymbolIcon DocumentText24}"
                               Command="{Binding ViewTranscriptCommand}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
