<Page x:Class="AiDev.Desktop.Views.Pages.SecretsPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:conv="clr-namespace:AiDev.Desktop.Converters"
         Title="Secrets">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
    </Page.Resources>

    <StackPanel Margin="24" MaxWidth="600">
        <TextBlock Text="Secrets" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Environment variables and secrets for this project"
                   FontSize="13"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,24" />

        <!-- Add new secret -->
        <wpfui:Card Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Add Secret" FontWeight="Medium" Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <wpfui:TextBox Grid.Column="0" PlaceholderText="KEY"
                                Text="{Binding NewKey, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,8,0" FontFamily="Consolas" />
                    <wpfui:TextBox Grid.Column="1" PlaceholderText="value"
                                Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,8,0" />
                    <wpfui:Button Grid.Column="2" Content="Add"
                               Appearance="Primary"
                               Command="{Binding AddSecretCommand}" />
                </Grid>
            </StackPanel>
        </wpfui:Card>

        <!-- Secrets list -->
        <wpfui:ProgressRing IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"
                         HorizontalAlignment="Left" />

        <ItemsControl ItemsSource="{Binding Secrets}"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisible}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            Padding="12,10"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Key}"
                                       FontFamily="Consolas"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center" />
                            <wpfui:TextBox Grid.Column="1"
                                        Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="8,0"
                                        FontFamily="Consolas" />
                            <wpfui:Button Grid.Column="2"
                                       Icon="{wpfui:SymbolIcon Delete24}"
                                       Appearance="Danger"
                                       Command="{Binding DataContext.RemoveSecretCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                       CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <wpfui:Button Content="Save All"
                   Appearance="Primary"
                   Icon="{wpfui:SymbolIcon Save24}"
                   Command="{Binding SaveCommand}"
                   Margin="0,16,0,0"
                   IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolToVisible}}" />
    </StackPanel>
</Page>
