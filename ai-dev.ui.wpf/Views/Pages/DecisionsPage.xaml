<Page x:Class="AiDev.Desktop.Views.Pages.DecisionsPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:conv="clr-namespace:AiDev.Desktop.Converters"
         Title="Decisions">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:PriorityColorConverter x:Key="PriorityColor" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Decisions" FontSize="28" FontWeight="SemiBold" />
            <CheckBox Content="Show resolved"
                      IsChecked="{Binding ShowResolved}"
                      Margin="20,0,0,0"
                      VerticalAlignment="Center"
                      Command="{Binding LoadCommand}" />
        </StackPanel>

        <!-- Decision list -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="0,0,16,0">
            <ListBox ItemsSource="{Binding Decisions}"
                     SelectedItem="{Binding SelectedDecision}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <EventSetter Event="MouseDoubleClick"
                                     Handler="DecisionItem_DoubleClick" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                                    <Border Width="3" CornerRadius="2"
                                            Background="{Binding Priority, Converter={StaticResource PriorityColor}}"
                                            Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Subject}"
                                               FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{Binding From, Mode=OneWay}" />
                                    <Run Text="·" />
                                    <Run Text="{Binding Status.Value, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Decision detail + chat -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="16,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Decision body -->
            <StackPanel Grid.Row="0"
                        Visibility="{Binding SelectedDecision, Converter={StaticResource BoolToVisible}}"
                        Margin="0,0,0,16">
                <TextBlock Text="{Binding SelectedDecision.Subject}"
                           FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                           Margin="0,0,0,8">
                    <Run Text="From:" FontWeight="Medium" />
                    <Run Text="{Binding SelectedDecision.From, Mode=OneWay}" />
                    <Run Text="  Blocks:" FontWeight="Medium" />
                    <Run Text="{Binding SelectedDecision.Blocks, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Text="{Binding SelectedDecision.Body}"
                           TextWrapping="Wrap" FontSize="13" LineHeight="20" />
            </StackPanel>

            <Separator Grid.Row="1" Margin="0,0,0,8"
                       Visibility="{Binding SelectedDecision, Converter={StaticResource BoolToVisible}}" />

            <!-- Chat messages -->
            <ScrollViewer Grid.Row="2"
                          Visibility="{Binding SelectedDecision, Converter={StaticResource BoolToVisible}}">
                <ItemsControl ItemsSource="{Binding ChatMessages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" Padding="12,8"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding From}"
                                               FontWeight="SemiBold" FontSize="12"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap" FontSize="13" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Reply + resolve -->
            <StackPanel Grid.Row="3"
                        Visibility="{Binding SelectedDecision, Converter={StaticResource BoolToVisible}}"
                        Margin="0,8,0,0">
                <wpfui:TextBox PlaceholderText="Reply..."
                            Text="{Binding ReplyText, UpdateSourceTrigger=PropertyChanged}"
                            AcceptsReturn="True"
                            Height="80"
                            Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <wpfui:Button Content="Send Reply"
                               Appearance="Primary"
                               Command="{Binding SendReplyCommand}"
                               IsEnabled="{Binding IsSendingReply, Converter={StaticResource InverseBoolToVisible}}"
                               Margin="0,0,8,0" />
                    <wpfui:Button Content="Resolve"
                               Appearance="Success"
                               Icon="{wpfui:SymbolIcon Checkmark24}"
                               Command="{Binding ResolveDecisionCommand}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
