<Page x:Class="AiDev.Desktop.Views.Pages.TranscriptPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:conv="clr-namespace:AiDev.Desktop.Converters"
         Title="Transcript">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,16">
            <TextBlock FontSize="28" FontWeight="SemiBold">
                <Run Text="Transcript" />
                <Run Text="—" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Run Text="{Binding Agent.Name, Mode=OneWay}"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </TextBlock>
        </StackPanel>

        <!-- Date list -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="0,0,12,0">
            <ListBox ItemsSource="{Binding Dates}"
                     SelectedItem="{Binding SelectedDate}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <EventSetter Event="MouseDown" Handler="Date_MouseDown" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Value}" Padding="4,6" FontSize="12" FontFamily="Consolas" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Transcript content -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="16,0,0,0">
            <TextBlock Text="{Binding TranscriptContent}"
                       TextWrapping="Wrap"
                       FontFamily="Consolas"
                       FontSize="12"
                       LineHeight="20"
                       Visibility="{Binding TranscriptContent, Converter={StaticResource NullToVisible}}" />
        </ScrollViewer>
    </Grid>
</Page>
